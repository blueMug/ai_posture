.page {
  min-height: 100vh;
  padding: 220rpx 28rpx 160rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at 18% 8%, rgba(255, 233, 92, 0.28), transparent 34%),
    radial-gradient(circle at 84% 18%, rgba(156, 231, 255, 0.24), transparent 36%),
    linear-gradient(180deg, #171717 0%, #0d0d0d 56%, #080808 100%);
}

.search-card {
  height: 88rpx;
  padding: 0 24rpx;
  border-radius: 28rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.16);
  border: 1rpx solid rgba(255, 255, 255, 0.3);
}

.search-icon {
  margin-right: 14rpx;
  color: rgba(255, 255, 255, 0.86);
  font-size: 34rpx;
}

.search-input {
  flex: 1;
  min-width: 0;
  height: 88rpx;
  color: #ffffff;
  font-size: 26rpx;
}

.search-placeholder {
  color: rgba(255, 255, 255, 0.72);
}

.search-clear {
  flex: 0 0 auto;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  color: #111111;
  font-size: 22rpx;
  font-weight: 700;
  background: #ffe95c;
}

.empty-state {
  margin-top: 32rpx;
  padding: 34rpx 28rpx;
  border-radius: 30rpx;
  text-align: center;
  background: rgba(255, 255, 255, 0.12);
  border: 1rpx solid rgba(255, 255, 255, 0.24);
}

.empty-title {
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
}

.empty-desc {
  margin-top: 12rpx;
  color: rgba(255, 255, 255, 0.76);
  font-size: 24rpx;
}

.category {
  margin-top: 36rpx;
}

.category-head {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  margin-bottom: 20rpx;
  padding: 0 6rpx;
}

.category-title {
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 700;
}

.category-subtitle {
  margin-top: 8rpx;
  color: rgba(255, 255, 255, 0.74);
  font-size: 23rpx;
}

.category-count {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  color: #111111;
  font-size: 22rpx;
  font-weight: 700;
  background: #ffe95c;
}

.pose-list {
  display: flex;
  flex-direction: column;
}

.pose-card {
  display: flex;
  min-height: 248rpx;
  margin-bottom: 24rpx;
  padding: 18rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.22);
  border-radius: 36rpx;
  box-sizing: border-box;
  background: rgba(255, 255, 255, 0.12);
  box-shadow: 0 24rpx 70rpx rgba(0, 0, 0, 0.28);
  overflow: hidden;
}

.preview {
  position: relative;
  flex: 0 0 210rpx;
  height: 212rpx;
  border-radius: 28rpx;
  overflow: hidden;
}

.preview-shine {
  position: absolute;
  left: -40rpx;
  top: -70rpx;
  width: 190rpx;
  height: 190rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.34);
}

.mini-stage {
  position: absolute;
  left: 16rpx;
  right: 16rpx;
  top: 18rpx;
  bottom: 16rpx;
}

.mini-guide-image {
  position: absolute;
  left: 0;
  top: 0;
  z-index: 2;
  width: 100%;
  height: 100%;
  opacity: 0.96;
}

.mini-image-error {
  position: absolute;
  left: 16rpx;
  right: 16rpx;
  top: 50%;
  z-index: 4;
  transform: translateY(-50%);
  padding: 10rpx 8rpx;
  border-radius: 16rpx;
  color: rgba(255, 255, 255, 0.88);
  font-size: 22rpx;
  text-align: center;
  background: rgba(0, 0, 0, 0.38);
}

.badge {
  position: absolute;
  right: 14rpx;
  bottom: 14rpx;
  z-index: 3;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  color: #111111;
  font-size: 21rpx;
  font-weight: 700;
  background: rgba(255, 255, 255, 0.9);
}

.preview-tip {
  position: absolute;
  left: 14rpx;
  bottom: 14rpx;
  z-index: 3;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  color: rgba(255, 255, 255, 0.9);
  font-size: 21rpx;
  font-weight: 700;
  background: rgba(0, 0, 0, 0.62);
}

.pose-info {
  flex: 1;
  min-width: 0;
  padding: 8rpx 4rpx 4rpx 24rpx;
  box-sizing: border-box;
}

.pose-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.pose-name {
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 700;
}

.pose-action {
  flex: 0 0 auto;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  color: #111111;
  font-size: 22rpx;
  font-weight: 700;
  background: #ffe95c;
}

.pose-tip {
  margin-top: 16rpx;
  color: rgba(255, 233, 92, 0.92);
  font-size: 24rpx;
}

.pose-desc {
  margin-top: 12rpx;
  color: rgba(255, 255, 255, 0.78);
  font-size: 24rpx;
  line-height: 1.45;
}
