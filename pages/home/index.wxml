<view class="page" style="{{pageTopStyle}}">
  <view class="brand-copy">
    <view class="brand-name">出片姿势</view>
    <view class="brand-tagline">按场景推荐拍照姿势，照着模板轻松出片</view>
  </view>

  <view class="search-card">
    <view class="search-icon">⌕</view>
    <input
      class="search-input"
      value="{{searchKeyword}}"
      placeholder="搜索拍照姿势、姿势相机、旅行、街拍、穿搭"
      placeholder-class="search-placeholder"
      confirm-type="search"
      bindinput="onSearchInput"
    />
    <view wx:if="{{searchKeyword}}" class="search-clear" bindtap="clearSearch">清除</view>
  </view>

  <view wx:if="{{!searchKeyword && sceneTopics.length}}" class="topic-section">
    <view class="topic-section-head">
      <view class="topic-kicker">场景出片专题</view>
      <view class="topic-title">到了现场，直接抄这份拍照作业</view>
      <view class="topic-subtitle">每张卡片都是一个具体场景，点进去看 3 个拍法。</view>
    </view>

    <view class="topic-grid">
      <view
        wx:for="{{sceneTopics}}"
        wx:key="id"
        wx:for-item="topic"
        class="topic-card"
        data-topic-id="{{topic.id}}"
        bindtap="openSceneTopic"
      >
        <image
          wx:if="{{!retryingPoseImages[topic.id]}}"
          class="topic-image"
          src="{{topic.coverImage}}"
          mode="aspectFit"
          data-pose-id="{{topic.id}}"
          bindload="onPoseImageLoad"
          binderror="onPoseImageError"
        ></image>
        <view
          wx:if="{{!loadedPoseImages[topic.id] && !failedPoseImages[topic.id] && !retryingPoseImages[topic.id]}}"
          class="home-image-loading compact topic-loading"
        >
          <view class="home-loading-spinner"></view>
        </view>
        <view wx:if="{{failedPoseImages[topic.id]}}" class="mini-image-error">
          图片加载失败
        </view>
        <view class="topic-mask"></view>
        <view class="topic-copy">
          <view class="topic-card-title">{{topic.title}}</view>
          <view class="topic-card-desc">{{topic.promise}}</view>
        </view>
      </view>
    </view>

    <view class="topic-update-tip">更多场景持续更新中</view>
  </view>

  <view wx:if="{{!hasSearchResult}}" class="empty-state">
    <view class="empty-title">没有匹配姿势</view>
    <view class="empty-desc">试试“半身”“自拍”“全身”“背影”。</view>
  </view>

  <view wx:if="{{!searchKeyword && dailyRecommend.poses.length}}" class="daily-section">
    <view class="section-head">
      <view>
        <view class="section-kicker">今日推荐</view>
        <view class="section-title">{{dailyRecommend.title}}</view>
        <view class="section-subtitle">{{dailyRecommend.subtitle}}</view>
      </view>
      <view
        class="section-link"
        data-category-id="{{dailyRecommend.categoryId}}"
        bindtap="openCategory"
      >看全部</view>
    </view>

    <scroll-view
      class="daily-scroll"
      scroll-x
      enhanced
      show-scrollbar="{{false}}"
    >
      <view class="daily-list">
        <view
          wx:for="{{dailyRecommend.poses}}"
          wx:key="id"
          wx:for-item="pose"
          class="daily-card"
          data-pose-id="{{pose.id}}"
          bindtap="openPoseDetail"
        >
          <view class="daily-image-wrap" style="background: {{pose.gradient}};">
            <image
              wx:if="{{!retryingPoseImages[pose.id]}}"
              class="daily-image"
              src="{{pose.thumbnailImage || pose.guideImage}}"
              mode="{{pose.thumbnailMode || 'aspectFit'}}"
              data-pose-id="{{pose.id}}"
              bindload="onPoseImageLoad"
              binderror="onPoseImageError"
            ></image>
            <view
              wx:if="{{!loadedPoseImages[pose.id] && !failedPoseImages[pose.id] && !retryingPoseImages[pose.id]}}"
              class="home-image-loading"
            >
              <view class="home-loading-spinner"></view>
              <view class="home-loading-text">图片加载中</view>
            </view>
            <view wx:if="{{failedPoseImages[pose.id]}}" class="mini-image-error">
              图片加载失败
            </view>
          </view>
          <view class="daily-name">{{pose.name}}</view>
          <view
            class="daily-action"
            data-pose-id="{{pose.id}}"
            data-home-local="1"
            catchtap="openCamera"
          >照着拍</view>
        </view>
      </view>
    </scroll-view>
  </view>

  <view wx:if="{{!searchKeyword && hasSearchResult}}" class="more-head">
    <view class="more-kicker">按类型继续挑</view>
    <view class="more-desc">专题之外，也可以按姿势类型继续找。</view>
  </view>

  <view wx:if="{{!searchKeyword && typeEntries.length}}" class="type-entry-grid">
    <view
      wx:for="{{typeEntries}}"
      wx:key="id"
      wx:for-item="entry"
      class="type-entry-card"
      data-category-id="{{entry.id}}"
      bindtap="openCategory"
    >
      <view class="type-entry-copy">
        <view class="type-entry-name">{{entry.name}}</view>
        <view class="type-entry-desc">{{entry.subtitle}}</view>
      </view>
      <view class="type-entry-image-wrap">
        <image
          wx:if="{{!retryingPoseImages[entry.id]}}"
          class="type-entry-image"
          src="{{entry.coverImage}}"
          mode="aspectFit"
          data-pose-id="{{entry.id}}"
          bindload="onPoseImageLoad"
          binderror="onPoseImageError"
        ></image>
        <view
          wx:if="{{!loadedPoseImages[entry.id] && !failedPoseImages[entry.id] && !retryingPoseImages[entry.id]}}"
          class="home-image-loading compact"
        >
          <view class="home-loading-spinner"></view>
        </view>
        <view wx:if="{{failedPoseImages[entry.id]}}" class="mini-image-error type-entry-image-error">
          图片加载失败
        </view>
      </view>
    </view>
  </view>

  <view
    wx:if="{{searchKeyword}}"
    wx:for="{{poseCategories}}"
    wx:key="id"
    wx:for-item="category"
    class="category"
  >
    <view class="category-head">
      <view>
        <view
          class="category-title"
          data-category-id="{{category.id}}"
          bindtap="openCategory"
        >{{category.name}}</view>
        <view class="category-subtitle">{{category.subtitle}}</view>
      </view>
      <view
        class="category-count"
        data-category-id="{{category.id}}"
        bindtap="openCategory"
      >共 {{category.totalPoseCount}} 个</view>
    </view>

    <view class="pose-list">
      <view
        wx:for="{{category.poses}}"
        wx:key="id"
        wx:for-item="pose"
        class="pose-card"
        data-pose-id="{{pose.id}}"
        bindtap="openPoseDetail"
      >
        <view
          class="preview"
          style="background: {{pose.gradient}};"
          data-pose-id="{{pose.id}}"
          catchtap="openPoseDetail"
        >
          <view class="preview-shine"></view>
          <view class="mini-stage">
            <image
              wx:if="{{!retryingPoseImages[pose.id]}}"
              class="mini-guide-image"
              src="{{pose.thumbnailImage || pose.guideImage}}"
              mode="{{pose.thumbnailMode || 'aspectFit'}}"
              data-pose-id="{{pose.id}}"
              bindload="onPoseImageLoad"
              binderror="onPoseImageError"
            ></image>
            <view
              wx:if="{{!loadedPoseImages[pose.id] && !failedPoseImages[pose.id] && !retryingPoseImages[pose.id]}}"
              class="home-image-loading"
            >
              <view class="home-loading-spinner"></view>
              <view class="home-loading-text">图片加载中</view>
            </view>
            <view wx:if="{{failedPoseImages[pose.id]}}" class="mini-image-error">
              图片加载失败
            </view>
          </view>
        </view>

        <view class="pose-info">
          <view class="pose-title-row">
            <view class="pose-name">{{pose.name}}</view>
            <view
              class="pose-action"
              data-pose-id="{{pose.id}}"
              catchtap="openCamera"
            >拍照</view>
          </view>
          <view class="pose-tip">{{pose.tip}}</view>
        </view>
      </view>
    </view>
  </view>

  <view wx:if="{{adSlot.visible}}" class="ad-card">
    <view wx:if="{{adSlot.isMock}}" class="mock-ad">
      <view class="mock-ad-label">广告</view>
      <view class="mock-ad-copy">
        <view class="mock-ad-title">{{adSlot.mockTitle}}</view>
        <view class="mock-ad-desc">{{adSlot.mockDesc}}</view>
      </view>
      <view class="mock-ad-action">{{adSlot.mockAction}}</view>
    </view>
    <ad
      wx:else
      unit-id="{{adSlot.unitId}}"
      ad-type="{{adSlot.adType}}"
    ></ad>
  </view>
</view>
