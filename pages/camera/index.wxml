<view class="page">
  <camera
    wx:if="{{privacyAccepted}}"
    class="camera"
    device-position="{{devicePosition}}"
    flash="off"
    resolution="high"
    zoom="{{cameraZoom}}"
    bindinitdone="onCameraInitDone"
    binderror="onCameraError"
  >
    <cover-view class="pose-stage" bindtap="closeSettingsPanel">
      <cover-view
        wx:if="{{currentTemplate.guideImage}}"
        class="pose-guide-box"
        style="{{guideBoxStyle}}"
        bindtap="closeSettingsPanel"
        catchtouchstart="onGuideDragStart"
        catchtouchmove="onGuideDragMove"
        catchtouchend="onGuideDragEnd"
        catchtouchcancel="onGuideDragEnd"
      >
        <cover-view class="pose-guide-layer">
          <cover-image
            wx:if="{{guideMode == 'outline'}}"
            class="pose-guide-image pose-guide-shadow"
            src="{{currentTemplate.guideImage}}"
          ></cover-image>
          <cover-image
            wx:if="{{guideMode == 'outline'}}"
            class="pose-guide-image pose-guide-boost"
            src="{{currentTemplate.guideImage}}"
          ></cover-image>
          <cover-image
            class="pose-guide-image pose-guide-main {{guideImageClass}}"
            src="{{currentTemplate.guideImage}}"
            binderror="onGuideImageError"
          ></cover-image>
        </cover-view>
      </cover-view>
      <cover-view wx:if="{{guideLoadFailed}}" class="guide-error-tip">
        轮廓加载失败，请检查图片域名
      </cover-view>
      <cover-view wx:if="{{countdownActive}}" class="countdown-mask">
        <cover-view class="countdown-number">{{countdownRemaining}}</cover-view>
      </cover-view>
    </cover-view>

    <cover-view class="camera-settings">
      <cover-view
        class="settings-trigger {{settingsPanelOpen ? 'active' : ''}}"
        catchtap="toggleSettingsPanel"
      >⚙</cover-view>
      <cover-view wx:if="{{settingsPanelOpen}}" class="settings-panel">
        <cover-view class="settings-title">拍摄设置</cover-view>
        <cover-view class="settings-item">
          <cover-view class="settings-label">轮廓大小</cover-view>
          <cover-view class="scale-control">
            <cover-view class="scale-step-btn" catchtap="decreaseGuideScale">-</cover-view>
            <cover-view class="scale-percent" catchtap="resetGuideScale">{{guideScaleText}}</cover-view>
            <cover-view class="scale-step-btn" catchtap="increaseGuideScale">+</cover-view>
          </cover-view>
        </cover-view>
        <cover-view class="settings-actions">
          <cover-view
            class="settings-chip {{guideVisible ? 'active' : ''}}"
            catchtap="toggleGuide"
          >引导 {{guideVisible ? guideModeText : '关'}}</cover-view>
          <cover-view
            class="settings-chip {{keepGuideForConfirm ? 'active' : ''}}"
            catchtap="toggleKeepGuideForConfirm"
          >拍后带轮廓 {{keepGuideForConfirm ? '开' : '关'}}</cover-view>
          <cover-view
            class="settings-chip {{countdownSeconds > 0 ? 'active' : ''}}"
            catchtap="cycleCountdown"
          >{{countdownText}}</cover-view>
          <cover-view
            class="settings-chip {{shootingTipsEnabled ? 'active' : ''}}"
            catchtap="toggleShootingTips"
          >拍摄提示 {{shootingTipsEnabled ? '开' : '关'}}</cover-view>
        </cover-view>
      </cover-view>
    </cover-view>

    <cover-view
      wx:if="{{shootingTipsEnabled && shootingGuide && shootingGuide.hasText && !countdownActive}}"
      class="camera-shooting-guide"
    >
      <cover-view wx:if="{{shootingGuide.actionText}}" class="camera-guide-item">
        <cover-view class="camera-guide-label">动作</cover-view>
        <cover-view class="camera-guide-text">{{shootingGuide.actionText}}</cover-view>
      </cover-view>
      <cover-view wx:if="{{shootingGuide.compositionText}}" class="camera-guide-item">
        <cover-view class="camera-guide-label">构图</cover-view>
        <cover-view class="camera-guide-text">{{shootingGuide.compositionText}}</cover-view>
      </cover-view>
    </cover-view>

    <cover-view
      wx:if="{{guideUsageTipVisible}}"
      class="guide-usage-tip"
      catchtap="dismissGuideUsageTip"
    >
      <cover-view class="guide-usage-title">姿势可以拖动对齐</cover-view>
      <cover-view class="guide-usage-desc">点左上设置，可调整轮廓大小和倒计时</cover-view>
    </cover-view>
  </camera>
  <view wx:else class="privacy-wait">
    <view class="privacy-title">使用相机前需要确认权限说明</view>
    <view class="privacy-desc">我们会先说明相机、相册、本地收藏和使用记录的用途。</view>
  </view>

  <view wx:if="{{privacyAccepted}}" class="bottom-panel safe-area-bottom" bindtap="closeSettingsPanel">
    <view class="shoot-row">
      <view class="left-actions">
        <view
          wx:if="{{latestPhotoPath}}"
          class="recent-photo-btn"
          bindtap="previewSessionPhotos"
          aria-label="查看本次拍摄照片"
        >
          <image class="recent-photo-image" src="{{latestPhotoPath}}" mode="aspectFill"></image>
          <view wx:if="{{sessionPhotoCount > 1}}" class="recent-photo-count">{{sessionPhotoCount}}</view>
        </view>
      </view>
      <view class="shutter-group">
        <view class="shutter" bindtap="takePhoto">
          <view class="shutter-inner"></view>
        </view>
        <view class="switch-icon-btn" bindtap="switchCamera" aria-label="切换前后镜头">
          <image
            class="switch-camera-image"
            src="/static/icons/camera-switch.svg"
            mode="aspectFit"
          ></image>
        </view>
      </view>
      <view class="right-actions">
        <view class="select-pose-btn" bindtap="backToPoseGallery">选姿势</view>
      </view>
    </view>
    <view class="camera-zoom-row">
      <view class="zoom-label">1x</view>
      <slider
        class="zoom-slider"
        min="1"
        max="{{cameraMaxZoom}}"
        step="0.1"
        value="{{cameraZoom}}"
        activeColor="#ffe95c"
        backgroundColor="rgba(255, 255, 255, 0.26)"
        block-color="#ffffff"
        block-size="22"
        bindchanging="onCameraZoomChanging"
        bindchange="onCameraZoomChange"
      />
      <view class="zoom-label">{{cameraZoomText}}</view>
    </view>
  </view>
</view>
