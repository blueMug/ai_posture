<view class="page">
  <image class="photo" src="{{photoPath}}" mode="aspectFit"></image>
  <image
    wx:if="{{confirmWithGuide && guidePreviewVisible && guideImage && guideStyleReady}}"
    class="guide-preview"
    src="{{guideImage}}"
    mode="scaleToFill"
    style="{{guideStyle}}"
    binderror="onGuidePreviewError"
  ></image>

  <view class="top-bar">
    <button
      wx:if="{{confirmWithGuide}}"
      class="back-btn guide-visibility-btn {{guidePreviewVisible ? 'active' : ''}}"
      bindtap="toggleGuidePreview"
    >{{guidePreviewVisible ? '关轮廓' : '开轮廓'}}</button>
    <view wx:else class="back-btn" bindtap="retake">重拍</view>
    <view class="title">{{confirmWithGuide ? '确认轮廓' : '照片预览'}}</view>
    <view class="placeholder"></view>
  </view>

  <view wx:if="{{confirmWithGuide}}" class="bottom-panel safe-area-bottom">
    <view wx:if="{{shareCard.visible}}" class="share-card">
      <view class="share-copy">
        <view class="share-kicker">{{shareCard.kicker}}</view>
        <view class="share-title">{{shareCard.title}}</view>
        <view class="share-brand">
          <image class="share-logo" src="{{shareBrandLogo}}" mode="aspectFit"></image>
          <view class="share-brand-text">出片姿势小程序</view>
        </view>
      </view>
      <button class="share-pose-btn" open-type="share">{{shareCard.buttonText}}</button>
    </view>
    <view class="confirm-actions">
      <button class="discard-btn" bindtap="retake">放弃</button>
      <button class="share-photo-btn" bindtap="sharePhoto">分享照片</button>
      <button class="accept-btn" bindtap="savePhoto">保存</button>
    </view>
  </view>

  <view wx:else class="bottom-panel safe-area-bottom">
    <view wx:if="{{shareCard.visible}}" class="share-card">
      <view class="share-copy">
        <view class="share-kicker">{{shareCard.kicker}}</view>
        <view class="share-title">{{shareCard.title}}</view>
        <view class="share-brand">
          <image class="share-logo" src="{{shareBrandLogo}}" mode="aspectFit"></image>
          <view class="share-brand-text">出片姿势小程序</view>
        </view>
      </view>
      <button class="share-pose-btn" open-type="share">{{shareCard.buttonText}}</button>
    </view>
    <view class="photo-actions">
      <button class="share-photo-btn" bindtap="sharePhoto">分享照片</button>
      <button class="save-btn" bindtap="savePhoto">保存到相簿</button>
    </view>
  </view>
</view>
