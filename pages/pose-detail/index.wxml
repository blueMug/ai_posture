<view class="page">
  <view class="top-bar">
    <view class="back-btn" bindtap="backToHome">返回</view>
    <view class="title">姿势详情</view>
    <view class="placeholder"></view>
  </view>

  <view class="content">
    <view class="copy">
      <view class="pose-name">{{pose.name}}</view>
      <view class="pose-tip">{{pose.tip}}</view>
      <view class="pose-desc">{{pose.description}}</view>
    </view>

    <view class="photo-card" style="background: {{pose.gradient}};">
      <view class="photo-glow"></view>
      <image
        class="pose-photo"
        src="{{displayImage}}"
        mode="aspectFit"
        bindtap="openCamera"
        binderror="onImageError"
      ></image>
      <view class="tap-tip">点图拍照</view>
    </view>

    <view wx:if="{{shootingGuide}}" class="shooting-guide-card">
      <view wx:if="{{shootingGuide.items.length}}" class="guide-list">
        <view
          wx:for="{{shootingGuide.items}}"
          wx:key="label"
          wx:for-item="item"
          class="guide-item {{item.label == '避坑' ? 'avoid' : ''}}"
        >
          <view class="guide-label">{{item.label}}</view>
          <view class="guide-text">{{item.text}}</view>
        </view>
      </view>
    </view>

  </view>

  <image
    wx:if="{{preloadedGuideImage}}"
    class="preload-guide-image"
    src="{{preloadedGuideImage}}"
    mode="scaleToFill"
  ></image>

  <view class="bottom-panel safe-area-bottom">
    <button class="share-btn" open-type="share">分享同款</button>
    <button class="favorite-btn {{isFavorite ? 'active' : ''}}" bindtap="toggleFavorite">
      {{isFavorite ? '已收藏' : '收藏'}}
    </button>
    <button class="shoot-btn" bindtap="openCamera">照着拍</button>
  </view>
</view>
