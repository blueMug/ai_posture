<view class="page">
  <view class="top-bar">
    <view class="back-btn" bindtap="backToHome">返回</view>
    <view class="title">姿势详情</view>
    <view class="placeholder"></view>
  </view>

  <view class="content">
    <view class="copy">
      <view class="pose-name">{{pose.name}}</view>
    </view>

    <view class="photo-card" style="background: {{pose.gradient}};">
      <view class="photo-glow"></view>
      <image
        wx:if="{{displayImage}}"
        class="pose-photo"
        src="{{displayImage}}"
        mode="aspectFit"
        bindtap="openCamera"
        bindload="onImageLoad"
        binderror="onImageError"
      ></image>
      <view wx:if="{{imageLoading}}" class="image-loading">
        <view class="loading-spinner"></view>
        <view class="loading-text">图片加载中</view>
      </view>
      <view
        wx:if="{{imageLoadFailed}}"
        class="image-error"
        catchtap="retryDetailImage"
      >图片加载失败，点击重试</view>
    </view>

    <view wx:if="{{detailGuide && detailGuide.hasImageText}}" class="image-note">
      <view class="image-note-label">适合</view>
      <view class="image-note-text">{{detailGuide.imageText}}</view>
    </view>

    <view wx:if="{{detailGuide && detailGuide.hasActionPoints}}" class="action-card">
      <view class="section-title">动作要点</view>
      <view class="action-list">
        <view
          wx:for="{{detailGuide.actionPoints}}"
          wx:key="*this"
          class="action-item"
        >
          <view class="action-dot"></view>
          <view class="action-text">{{item}}</view>
        </view>
      </view>
    </view>

    <view wx:if="{{detailGuide && detailGuide.hasDetails}}" class="detail-card">
      <view class="detail-header" bindtap="toggleDetailExpanded">
        <view class="section-title">详细说明</view>
        <view class="detail-toggle">{{detailExpanded ? '收起' : '展开'}}</view>
      </view>
      <view wx:if="{{detailExpanded}}" class="guide-list">
        <view
          wx:for="{{detailGuide.detailItems}}"
          wx:key="label"
          wx:for-item="item"
          class="guide-item"
        >
          <view class="guide-label">{{item.label}}</view>
          <view class="guide-content">
            <block wx:if="{{item.sections && item.sections.length}}">
              <view
                wx:for="{{item.sections}}"
                wx:key="id"
                wx:for-item="section"
                class="guide-section {{section.tone}}"
              >
                <view class="guide-section-title">{{section.title}}</view>
                <view class="guide-section-lines">
                  <view
                    wx:for="{{section.lines}}"
                    wx:key="*this"
                    wx:for-item="line"
                    class="guide-section-line"
                  >
                    <view wx:if="{{section.lines.length > 1}}" class="guide-section-dot"></view>
                    <view class="guide-section-text">{{line}}</view>
                  </view>
                </view>
              </view>
            </block>
            <view wx:else class="guide-text">{{item.text}}</view>
          </view>
        </view>
      </view>
    </view>

  </view>

  <image
    wx:if="{{preloadedGuideImage}}"
    class="preload-guide-image"
    src="{{preloadedGuideImage}}"
    mode="scaleToFill"
  ></image>
  <image
    wx:for="{{preloadedCameraImages}}"
    wx:key="*this"
    class="preload-guide-image"
    src="{{item}}"
    mode="scaleToFill"
  ></image>

  <view class="bottom-panel safe-area-bottom">
    <button class="share-btn" open-type="share">分享同款</button>
    <button class="favorite-btn {{isFavorite ? 'active' : ''}}" bindtap="toggleFavorite">
      {{isFavorite ? '已收藏' : '收藏'}}
    </button>
    <button class="shoot-btn" bindtap="openCamera">照着拍</button>
  </view>
</view>
