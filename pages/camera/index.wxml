<view class="page">
  <camera
    class="camera"
    device-position="{{devicePosition}}"
    flash="off"
    resolution="high"
    zoom="{{cameraZoom}}"
    bindinitdone="onCameraInitDone"
    binderror="onCameraError"
  >
    <cover-view class="top-bar">
      <cover-view class="title">姿势引导相机</cover-view>
    </cover-view>

    <cover-view class="pose-stage">
      <cover-view class="pose-name">{{currentTemplate.name}}</cover-view>
      <cover-view
        wx:if="{{currentTemplate.guideImage}}"
        class="pose-guide-box"
        style="{{guideBoxStyle}}"
        bindtouchstart="onGuideDragStart"
        catchtouchmove="onGuideDragMove"
        bindtouchend="onGuideDragEnd"
        bindtouchcancel="onGuideDragEnd"
      >
        <cover-image
          wx:if="{{guideMode == 'outline'}}"
          class="pose-guide-image pose-guide-shadow"
          src="{{currentTemplate.guideImage}}"
        ></cover-image>
        <cover-image
          wx:if="{{guideMode == 'outline'}}"
          class="pose-guide-image pose-guide-boost"
          src="{{currentTemplate.guideImage}}"
        ></cover-image>
        <cover-image
          class="pose-guide-image pose-guide-main {{guideImageClass}}"
          src="{{currentTemplate.guideImage}}"
          binderror="onGuideImageError"
        ></cover-image>
      </cover-view>
      <cover-view wx:if="{{guideLoadFailed}}" class="guide-error-tip">
        轮廓加载失败，请检查图片域名
      </cover-view>
    </cover-view>
  </camera>

  <view class="bottom-panel safe-area-bottom">
    <view class="shoot-row">
      <view
        class="guide-toggle-btn {{guideVisible ? 'active' : 'muted'}} {{showModelToggle ? 'model-toggle-btn' : ''}}"
        bindtap="toggleGuide"
        aria-label="{{guideToggleTitle}}"
      >
        <block wx:if="{{showModelToggle}}">
          <image
            class="model-toggle-image"
            src="{{modelToggleImage}}"
            mode="aspectFill"
          ></image>
          <view class="model-toggle-mask">{{guideVisible ? guideModeText : '引导关'}}</view>
        </block>
        <view wx:else class="eye-icon">
          <view class="eye-dot"></view>
          <view wx:if="{{!guideVisible}}" class="eye-slash"></view>
        </view>
      </view>
      <view class="shutter-group">
        <view class="shutter" bindtap="takePhoto">
          <view class="shutter-inner"></view>
        </view>
        <view class="switch-icon-btn" bindtap="switchCamera">⟳</view>
      </view>
      <view class="select-pose-btn" bindtap="backToHome">选姿势</view>
    </view>
    <view class="camera-zoom-row">
      <view class="zoom-label">1x</view>
      <slider
        class="zoom-slider"
        min="1"
        max="{{cameraMaxZoom}}"
        step="0.1"
        value="{{cameraZoom}}"
        activeColor="#ffe95c"
        backgroundColor="rgba(255, 255, 255, 0.26)"
        block-color="#ffffff"
        block-size="22"
        bindchanging="onCameraZoomChanging"
        bindchange="onCameraZoomChange"
      />
      <view class="zoom-label">{{cameraZoomText}}</view>
    </view>
  </view>
</view>
