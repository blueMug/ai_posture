<view class="page" style="{{pageTopStyle}}">
  <view class="top-bar">
    <view class="placeholder"></view>
    <view class="title">姿势分类</view>
    <view class="placeholder"></view>
  </view>

  <view class="search-card">
    <view class="search-icon">⌕</view>
    <input
      class="search-input"
      value="{{searchKeyword}}"
      placeholder="搜索半身、全身、自拍、景点、咖啡"
      placeholder-class="search-placeholder"
      confirm-type="search"
      bindinput="onSearchInput"
    />
    <view wx:if="{{searchKeyword}}" class="search-clear" bindtap="clearSearch">清除</view>
  </view>

  <view wx:if="{{!hasSearchResult}}" class="empty-state">
    <view class="empty-title">没有匹配照片</view>
    <view class="empty-desc">试试“半身”“自拍”“景点”“咖啡”。</view>
  </view>

  <scroll-view
    wx:if="{{hasSearchResult}}"
    class="category-nav"
    scroll-x
    enhanced
    show-scrollbar="{{false}}"
  >
    <view class="category-nav-inner">
      <view
        wx:for="{{categoryNavs}}"
        wx:key="id"
        wx:for-item="category"
        class="category-nav-chip {{activeCategoryId == category.id ? 'active' : ''}}"
        data-category-id="{{category.id}}"
        bindtap="scrollToCategory"
      >
        <text>{{category.name}}</text>
        <text class="category-nav-count">{{category.count}}</text>
      </view>
    </view>
  </scroll-view>

  <view wx:if="{{adSlot.visible}}" class="ad-card">
    <view wx:if="{{adSlot.isMock}}" class="mock-ad">
      <view class="mock-ad-label">广告</view>
      <view class="mock-ad-copy">
        <view class="mock-ad-title">{{adSlot.mockTitle}}</view>
        <view class="mock-ad-desc">{{adSlot.mockDesc}}</view>
      </view>
      <view class="mock-ad-action">{{adSlot.mockAction}}</view>
    </view>
    <ad
      wx:else
      unit-id="{{adSlot.unitId}}"
      ad-type="{{adSlot.adType}}"
    ></ad>
  </view>

  <view
    wx:for="{{poseCategories}}"
    wx:key="id"
    wx:for-item="category"
    class="category"
    id="gallery-category-{{category.id}}"
  >
    <view class="category-head">
      <view>
        <view class="category-title">{{category.name}}</view>
        <view class="category-subtitle">{{category.poses.length}} 个</view>
      </view>
    </view>

    <view class="photo-grid">
      <view
        wx:for="{{category.poses}}"
        wx:key="id"
        wx:for-item="pose"
        class="photo-card"
        data-pose-id="{{pose.id}}"
        bindtap="openPoseDetail"
      >
        <image
          class="pose-photo"
          src="{{pose.thumbnailImage || pose.modelImage || pose.detailImage}}"
          mode="aspectFill"
          data-pose-id="{{pose.id}}"
          binderror="onPoseImageError"
        ></image>
        <view
          wx:if="{{pose.isFavorite}}"
          class="favorite-chip active"
          data-pose-id="{{pose.id}}"
          catchtap="toggleFavorite"
        >收藏</view>
        <view wx:if="{{failedPoseImages[pose.id]}}" class="image-error">图片加载失败</view>
        <view class="photo-info">
          <view class="pose-name">{{pose.name}}</view>
          <view
            class="shoot-chip"
            data-pose-id="{{pose.id}}"
            catchtap="openCamera"
          >拍</view>
        </view>
      </view>
    </view>
  </view>
</view>
