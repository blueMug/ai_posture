<view class="page">
  <view class="top-bar">
    <view class="back-btn" bindtap="backToHome">返回</view>
    <view class="title">姿势详情</view>
    <view class="placeholder"></view>
  </view>

  <view class="content">
    <view class="copy">
      <view class="pose-name">{{pose.name}}</view>
      <view class="pose-tip">{{pose.tip}}</view>
      <view class="pose-desc">{{pose.description}}</view>
    </view>

    <view class="photo-card" style="background: {{pose.gradient}};">
      <view class="photo-glow"></view>
      <image
        class="pose-photo"
        src="{{displayImage}}"
        mode="aspectFit"
        bindtap="openCamera"
        binderror="onImageError"
      ></image>
      <view class="tap-tip">点图拍照</view>
    </view>

  </view>

  <view class="bottom-panel safe-area-bottom">
    <button class="share-btn" open-type="share">分享</button>
    <button class="favorite-btn {{isFavorite ? 'active' : ''}}" bindtap="toggleFavorite">
      {{isFavorite ? '已收藏' : '收藏'}}
    </button>
    <button class="shoot-btn" bindtap="openCamera">拍照</button>
  </view>
</view>
