.page {
  min-height: 100vh;
  padding: 88rpx 28rpx 160rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at 22% 8%, rgba(255, 233, 92, 0.24), transparent 34%),
    radial-gradient(circle at 86% 18%, rgba(156, 231, 255, 0.18), transparent 36%),
    linear-gradient(180deg, #171717 0%, #090909 100%);
}

.top-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 72rpx;
}

.back-btn,
.placeholder {
  width: 108rpx;
}

.back-btn {
  color: rgba(255, 255, 255, 0.86);
  font-size: 26rpx;
}

.title {
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 800;
}

.topic-hero {
  position: relative;
  min-height: 360rpx;
  margin-top: 26rpx;
  padding: 30rpx;
  border-radius: 40rpx;
  box-sizing: border-box;
  overflow: hidden;
  background:
    radial-gradient(circle at 88% 18%, rgba(255, 233, 92, 0.32), transparent 34%),
    linear-gradient(135deg, rgba(255, 255, 255, 0.2), rgba(255, 255, 255, 0.08));
  border: 1rpx solid rgba(255, 255, 255, 0.26);
  box-shadow: 0 28rpx 76rpx rgba(0, 0, 0, 0.3);
}

.topic-copy {
  position: relative;
  z-index: 2;
  width: 430rpx;
}

.topic-kicker {
  display: inline-flex;
  align-items: center;
  height: 40rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  color: #111111;
  font-size: 22rpx;
  font-weight: 900;
  background: #ffe95c;
}

.topic-title {
  margin-top: 18rpx;
  color: #ffffff;
  font-size: 46rpx;
  line-height: 1.18;
  font-weight: 900;
}

.topic-pain {
  margin-top: 16rpx;
  color: rgba(255, 255, 255, 0.82);
  font-size: 25rpx;
  line-height: 1.5;
}

.topic-promise {
  margin-top: 14rpx;
  color: rgba(255, 233, 92, 0.94);
  font-size: 25rpx;
  line-height: 1.45;
  font-weight: 800;
}

.topic-cover {
  position: absolute;
  right: -18rpx;
  bottom: -24rpx;
  width: 220rpx;
  height: 286rpx;
  opacity: 0.78;
}

.plan-section,
.share-card {
  margin-top: 32rpx;
}

.section-head {
  margin-bottom: 18rpx;
  padding: 0 6rpx;
}

.section-title {
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 900;
}

.section-subtitle {
  margin-top: 8rpx;
  color: rgba(255, 255, 255, 0.72);
  font-size: 23rpx;
  line-height: 1.42;
}

.plan-list {
  display: flex;
  flex-direction: column;
}

.plan-card {
  display: flex;
  margin-bottom: 20rpx;
  padding: 18rpx;
  border-radius: 34rpx;
  box-sizing: border-box;
  background: rgba(255, 255, 255, 0.13);
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  box-shadow: 0 22rpx 68rpx rgba(0, 0, 0, 0.24);
}

.plan-preview {
  position: relative;
  flex: 0 0 172rpx;
  height: 206rpx;
  border-radius: 26rpx;
  overflow: hidden;
}

.plan-image {
  position: absolute;
  left: 12rpx;
  right: 12rpx;
  top: 12rpx;
  bottom: 12rpx;
  width: calc(100% - 24rpx);
  height: calc(100% - 24rpx);
}

.image-error {
  position: absolute;
  left: 14rpx;
  right: 14rpx;
  top: 50%;
  transform: translateY(-50%);
  color: rgba(255, 255, 255, 0.84);
  font-size: 21rpx;
  text-align: center;
}

.plan-body {
  flex: 1;
  min-width: 0;
  padding-left: 20rpx;
  box-sizing: border-box;
}

.plan-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.plan-badge {
  max-width: 172rpx;
  padding: 7rpx 12rpx;
  border-radius: 999rpx;
  color: #111111;
  font-size: 20rpx;
  font-weight: 900;
  background: #ffe95c;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.shoot-action {
  flex: 0 0 auto;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  color: #ffffff;
  font-size: 21rpx;
  font-weight: 800;
  background: rgba(255, 255, 255, 0.16);
  border: 1rpx solid rgba(255, 255, 255, 0.22);
}

.plan-title {
  margin-top: 14rpx;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 900;
}

.plan-reason {
  margin-top: 8rpx;
  color: rgba(255, 255, 255, 0.76);
  font-size: 23rpx;
  line-height: 1.42;
  display: -webkit-box;
  overflow: hidden;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.plan-more {
  margin-top: 12rpx;
  color: rgba(255, 233, 92, 0.9);
  font-size: 22rpx;
  font-weight: 900;
}

.share-card {
  padding: 28rpx;
  border-radius: 34rpx;
  box-sizing: border-box;
  background: rgba(255, 255, 255, 0.1);
  border: 1rpx solid rgba(255, 255, 255, 0.18);
}

.share-title {
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 900;
}

.share-desc {
  margin-top: 10rpx;
  color: rgba(255, 255, 255, 0.74);
  font-size: 24rpx;
  line-height: 1.45;
}

.share-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 82rpx;
  margin-top: 20rpx;
  padding: 0;
  border-radius: 999rpx;
  color: #111111;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 1;
  background: #ffe95c;
}

.share-btn::after {
  border: 0;
}
