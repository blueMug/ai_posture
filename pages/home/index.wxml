<view class="page" style="{{pageTopStyle}}">
  <view class="brand-copy">
    <view class="brand-name">出片姿势</view>
    <view class="brand-tagline">按场景推荐拍照姿势，照着模板轻松出片</view>
  </view>

  <view class="search-card">
    <view class="search-icon">⌕</view>
    <input
      class="search-input"
      value="{{searchKeyword}}"
      placeholder="搜索拍照姿势、姿势相机、旅行、街拍、穿搭"
      placeholder-class="search-placeholder"
      confirm-type="search"
      bindinput="onSearchInput"
    />
    <view wx:if="{{searchKeyword}}" class="search-clear" bindtap="clearSearch">清除</view>
  </view>

  <view wx:if="{{!searchKeyword && sceneAdvisor.plans.length}}" class="advisor-section">
    <view class="advisor-hero">
      <view class="advisor-kicker">场景拍照导演</view>
      <view class="advisor-title">先选你在哪，再决定怎么拍</view>
    </view>

    <scroll-view
      class="scene-tab-scroll"
      scroll-x
      enhanced
      show-scrollbar="{{false}}"
    >
      <view class="scene-tab-list">
        <view
          wx:for="{{sceneTabs}}"
          wx:key="id"
          wx:for-item="scene"
          class="scene-tab {{scene.active ? 'active' : ''}}"
          data-scene-id="{{scene.id}}"
          bindtap="selectScene"
        >
          <image
            wx:if="{{!retryingPoseImages[scene.id]}}"
            class="scene-tab-image"
            src="{{scene.coverImage}}"
            mode="aspectFit"
            data-pose-id="{{scene.id}}"
            bindload="onPoseImageLoad"
            binderror="onPoseImageError"
          ></image>
          <view
            wx:if="{{!loadedPoseImages[scene.id] && !failedPoseImages[scene.id] && !retryingPoseImages[scene.id]}}"
            class="home-image-loading compact scene-tab-loading"
          >
            <view class="home-loading-spinner"></view>
          </view>
          <view class="scene-tab-copy">
            <view class="scene-tab-title">{{scene.title}}</view>
          </view>
        </view>
      </view>
    </scroll-view>

    <view class="advisor-head">
      <view>
        <view class="section-title">{{sceneAdvisor.title}}怎么拍</view>
        <view class="section-subtitle">{{sceneAdvisor.desc}}</view>
      </view>
      <view
        class="section-link"
        data-category-id="{{sceneAdvisor.categoryId}}"
        bindtap="openCategory"
      >更多</view>
    </view>

    <view class="advisor-plan-list">
      <view
        wx:for="{{sceneAdvisor.plans}}"
        wx:key="poseId"
        wx:for-item="plan"
        wx:for-index="planIndex"
        class="advisor-plan"
        data-pose-id="{{plan.poseId}}"
        data-plan-index="{{planIndex}}"
        bindtap="openAdvisorPlanDetail"
      >
        <view class="advisor-plan-preview" style="background: {{plan.gradient}};">
          <image
            wx:if="{{!retryingPoseImages[plan.poseId]}}"
            class="advisor-plan-image"
            src="{{plan.thumbnailImage}}"
            mode="aspectFit"
            data-pose-id="{{plan.poseId}}"
            bindload="onPoseImageLoad"
            binderror="onPoseImageError"
          ></image>
          <view
            wx:if="{{!loadedPoseImages[plan.poseId] && !failedPoseImages[plan.poseId] && !retryingPoseImages[plan.poseId]}}"
            class="home-image-loading"
          >
            <view class="home-loading-spinner"></view>
            <view class="home-loading-text">图片加载中</view>
          </view>
          <view wx:if="{{failedPoseImages[plan.poseId]}}" class="mini-image-error">
            图片加载失败
          </view>
        </view>
        <view class="advisor-plan-body">
          <view class="advisor-plan-top">
            <view class="advisor-plan-badge">{{plan.badge}}</view>
            <view
              class="advisor-plan-action"
              data-pose-id="{{plan.poseId}}"
              data-home-local="1"
              catchtap="openCamera"
            >照着拍</view>
          </view>
          <view class="advisor-plan-title">{{plan.title}}</view>
          <view class="advisor-plan-reason">{{plan.reason}}</view>
        </view>
      </view>
    </view>
  </view>

  <view wx:if="{{!hasSearchResult}}" class="empty-state">
    <view class="empty-title">没有匹配姿势</view>
    <view class="empty-desc">试试“半身”“自拍”“全身”“背影”。</view>
  </view>

  <view wx:if="{{!searchKeyword && dailyRecommend.poses.length}}" class="daily-section">
    <view class="section-head">
      <view>
        <view class="section-kicker">今日推荐</view>
        <view class="section-title">{{dailyRecommend.title}}</view>
        <view class="section-subtitle">{{dailyRecommend.subtitle}}</view>
      </view>
      <view
        class="section-link"
        data-category-id="{{dailyRecommend.categoryId}}"
        bindtap="openCategory"
      >看全部</view>
    </view>

    <scroll-view
      class="daily-scroll"
      scroll-x
      enhanced
      show-scrollbar="{{false}}"
    >
      <view class="daily-list">
        <view
          wx:for="{{dailyRecommend.poses}}"
          wx:key="id"
          wx:for-item="pose"
          class="daily-card"
          data-pose-id="{{pose.id}}"
          bindtap="openPoseDetail"
        >
          <view class="daily-image-wrap" style="background: {{pose.gradient}};">
            <image
              wx:if="{{!retryingPoseImages[pose.id]}}"
              class="daily-image"
              src="{{pose.thumbnailImage || pose.guideImage}}"
              mode="{{pose.thumbnailMode || 'aspectFit'}}"
              data-pose-id="{{pose.id}}"
              bindload="onPoseImageLoad"
              binderror="onPoseImageError"
            ></image>
            <view
              wx:if="{{!loadedPoseImages[pose.id] && !failedPoseImages[pose.id] && !retryingPoseImages[pose.id]}}"
              class="home-image-loading"
            >
              <view class="home-loading-spinner"></view>
              <view class="home-loading-text">图片加载中</view>
            </view>
            <view wx:if="{{failedPoseImages[pose.id]}}" class="mini-image-error">
              图片加载失败
            </view>
          </view>
          <view class="daily-name">{{pose.name}}</view>
          <view
            class="daily-action"
            data-pose-id="{{pose.id}}"
            data-home-local="1"
            catchtap="openCamera"
          >照着拍</view>
        </view>
      </view>
    </scroll-view>
  </view>

  <view wx:if="{{!searchKeyword && quickScenes.length}}" class="scene-section">
    <view class="section-head compact">
      <view>
        <view class="section-title">马上开拍</view>
        <view class="section-subtitle">不知道选什么，就从这几个高频场景开始。</view>
      </view>
    </view>

    <view class="scene-grid">
      <view
        wx:for="{{quickScenes}}"
        wx:key="categoryId"
        wx:for-item="scene"
        class="scene-card"
        data-category-id="{{scene.categoryId}}"
        bindtap="openCategory"
      >
        <image
          wx:if="{{!retryingPoseImages[scene.categoryId]}}"
          class="scene-image"
          src="{{scene.coverImage}}"
          mode="aspectFit"
          data-pose-id="{{scene.categoryId}}"
          bindload="onPoseImageLoad"
          binderror="onPoseImageError"
        ></image>
        <view
          wx:if="{{!loadedPoseImages[scene.categoryId] && !failedPoseImages[scene.categoryId] && !retryingPoseImages[scene.categoryId]}}"
          class="home-image-loading compact scene-card-loading"
        >
          <view class="home-loading-spinner"></view>
        </view>
        <view class="scene-mask"></view>
        <view class="scene-copy">
          <view class="scene-title">{{scene.title}}</view>
          <view class="scene-desc">{{scene.desc}}</view>
        </view>
      </view>
    </view>
  </view>

  <view wx:if="{{!searchKeyword && hasSearchResult}}" class="more-head">
    <view class="section-title">更多拍照灵感</view>
    <view class="section-subtitle">按场景挑一张，进入相机照着轮廓拍。</view>
  </view>

  <view
    wx:for="{{poseCategories}}"
    wx:key="id"
    wx:for-item="category"
    class="category"
  >
    <view class="category-head">
      <view>
        <view
          class="category-title"
          data-category-id="{{category.id}}"
          bindtap="openCategory"
        >{{category.name}}</view>
        <view class="category-subtitle">{{category.subtitle}}</view>
      </view>
      <view
        class="category-count"
        data-category-id="{{category.id}}"
        bindtap="openCategory"
      >共 {{category.totalPoseCount}} 个</view>
    </view>

    <view class="pose-list">
      <view
        wx:for="{{category.poses}}"
        wx:key="id"
        wx:for-item="pose"
        class="pose-card"
        data-pose-id="{{pose.id}}"
        bindtap="openPoseDetail"
      >
        <view
          class="preview"
          style="background: {{pose.gradient}};"
          data-pose-id="{{pose.id}}"
          catchtap="openPoseDetail"
        >
          <view class="preview-shine"></view>
          <view class="mini-stage">
            <image
              wx:if="{{!retryingPoseImages[pose.id]}}"
              class="mini-guide-image"
              src="{{pose.thumbnailImage || pose.guideImage}}"
              mode="{{pose.thumbnailMode || 'aspectFit'}}"
              data-pose-id="{{pose.id}}"
              bindload="onPoseImageLoad"
              binderror="onPoseImageError"
            ></image>
            <view
              wx:if="{{!loadedPoseImages[pose.id] && !failedPoseImages[pose.id] && !retryingPoseImages[pose.id]}}"
              class="home-image-loading"
            >
              <view class="home-loading-spinner"></view>
              <view class="home-loading-text">图片加载中</view>
            </view>
            <view wx:if="{{failedPoseImages[pose.id]}}" class="mini-image-error">
              图片加载失败
            </view>
          </view>
        </view>

        <view class="pose-info">
          <view class="pose-title-row">
            <view class="pose-name">{{pose.name}}</view>
            <view
              class="pose-action"
              data-pose-id="{{pose.id}}"
              catchtap="openCamera"
            >拍照</view>
          </view>
          <view class="pose-tip">{{pose.tip}}</view>
        </view>
      </view>
    </view>
  </view>

  <view wx:if="{{adSlot.visible}}" class="ad-card">
    <view wx:if="{{adSlot.isMock}}" class="mock-ad">
      <view class="mock-ad-label">广告</view>
      <view class="mock-ad-copy">
        <view class="mock-ad-title">{{adSlot.mockTitle}}</view>
        <view class="mock-ad-desc">{{adSlot.mockDesc}}</view>
      </view>
      <view class="mock-ad-action">{{adSlot.mockAction}}</view>
    </view>
    <ad
      wx:else
      unit-id="{{adSlot.unitId}}"
      ad-type="{{adSlot.adType}}"
    ></ad>
  </view>
</view>
