<view class="page">
  <view class="top-bar">
    <view class="placeholder"></view>
    <view class="title">姿势速览</view>
    <view class="placeholder"></view>
  </view>

  <view class="hero">
    <view class="hero-title">按分类快速挑照片</view>
    <view class="hero-desc">每行两张真人示例，点击照片看大图，点“拍”直接进入相机。</view>
  </view>

  <view class="search-card">
    <view class="search-icon">⌕</view>
    <input
      class="search-input"
      value="{{searchKeyword}}"
      placeholder="搜索半身、全身、街拍、背影、咖啡"
      placeholder-class="search-placeholder"
      confirm-type="search"
      bindinput="onSearchInput"
    />
    <view wx:if="{{searchKeyword}}" class="search-clear" bindtap="clearSearch">清除</view>
  </view>

  <view wx:if="{{!hasSearchResult}}" class="empty-state">
    <view class="empty-title">没有找到匹配照片</view>
    <view class="empty-desc">换个关键词试试，例如“半身”“全身”“街拍”“背影”。</view>
  </view>

  <view
    wx:for="{{poseCategories}}"
    wx:key="id"
    wx:for-item="category"
    class="category"
  >
    <view class="category-head">
      <view>
        <view class="category-title">{{category.name}}</view>
        <view class="category-subtitle">{{category.poses.length}} 个姿势</view>
      </view>
    </view>

    <view class="photo-grid">
      <view
        wx:for="{{category.poses}}"
        wx:key="id"
        wx:for-item="pose"
        class="photo-card"
        data-pose-id="{{pose.id}}"
        bindtap="openPoseDetail"
      >
        <image
          class="pose-photo"
          src="{{pose.thumbnailImage || pose.modelImage || pose.detailImage}}"
          mode="aspectFill"
          data-pose-id="{{pose.id}}"
          binderror="onPoseImageError"
        ></image>
        <view wx:if="{{failedPoseImages[pose.id]}}" class="image-error">图片加载失败</view>
        <view class="photo-info">
          <view class="pose-name">{{pose.name}}</view>
          <view
            class="shoot-chip"
            data-pose-id="{{pose.id}}"
            catchtap="openCamera"
          >拍</view>
        </view>
      </view>
    </view>
  </view>
</view>
