<view class="page">
  <view class="top-bar">
    <view class="placeholder"></view>
    <view class="title">个人</view>
    <view class="placeholder"></view>
  </view>

  <view class="hero">
    <view class="hero-title">拍照设置</view>
    <view class="hero-desc">当前只保留拍后确认轮廓设置，后续可以继续放个人偏好和历史记录。</view>
  </view>

  <view class="setting-card">
    <view class="setting-copy">
      <view class="setting-title">拍后确认轮廓</view>
      <view class="setting-desc">开启后，拍完会先用当前轮廓叠加预览，确认对齐后再保存原照片。</view>
    </view>
    <switch
      color="#ffe95c"
      checked="{{keepGuideForConfirm}}"
      bindchange="onGuideConfirmChange"
    />
  </view>
</view>
