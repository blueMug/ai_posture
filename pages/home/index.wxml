<view class="page">
  <view class="hero">
    <view class="eyebrow">AI Posture Camera</view>
    <view class="title">先选姿势，再打开相机</view>
    <view class="subtitle">按场景挑一个拍照模板，进入相机后按照线条摆姿势，照片里不会保留引导线。</view>
  </view>

  <view class="search-card">
    <view class="search-icon">⌕</view>
    <input
      class="search-input"
      value="{{searchKeyword}}"
      placeholder="搜索站姿、坐姿、回眸、穿搭、街拍"
      placeholder-class="search-placeholder"
      confirm-type="search"
      bindinput="onSearchInput"
    />
    <view wx:if="{{searchKeyword}}" class="search-clear" bindtap="clearSearch">清除</view>
  </view>

  <view wx:if="{{!hasSearchResult}}" class="empty-state">
    <view class="empty-title">没有找到匹配姿势</view>
    <view class="empty-desc">换个关键词试试，例如“站姿”“回眸”“半身”“穿搭”。</view>
  </view>

  <view
    wx:for="{{poseCategories}}"
    wx:key="id"
    wx:for-item="category"
    class="category"
  >
    <view class="category-head">
      <view>
        <view class="category-title">{{category.name}}</view>
        <view class="category-subtitle">{{category.subtitle}}</view>
      </view>
      <view class="category-count">{{category.poses.length}} 个姿势</view>
    </view>

    <view class="pose-list">
      <view
        wx:for="{{category.poses}}"
        wx:key="id"
        wx:for-item="pose"
        class="pose-card"
        data-pose-id="{{pose.id}}"
        bindtap="openPoseDetail"
      >
        <view
          class="preview"
          style="background: {{pose.gradient}};"
          data-pose-id="{{pose.id}}"
          catchtap="openPoseDetail"
        >
          <view class="preview-shine"></view>
          <view class="mini-stage">
            <image
              class="mini-guide-image"
              src="{{pose.thumbnailImage || pose.guideImage}}"
              mode="{{pose.thumbnailMode || 'aspectFit'}}"
              data-pose-id="{{pose.id}}"
              binderror="onPoseImageError"
            ></image>
            <view wx:if="{{failedPoseImages[pose.id]}}" class="mini-image-error">
              图片加载失败
            </view>
          </view>
          <view class="badge">{{pose.badge}}</view>
          <view wx:if="{{pose.modelImage && pose.detailImage}}" class="preview-tip">看大图</view>
        </view>

        <view class="pose-info">
          <view class="pose-title-row">
            <view class="pose-name">{{pose.name}}</view>
            <view
              class="pose-action"
              data-pose-id="{{pose.id}}"
              catchtap="openCamera"
            >开始拍</view>
          </view>
          <view class="pose-tip">{{pose.tip}}</view>
          <view class="pose-desc">{{pose.description}}</view>
        </view>
      </view>
    </view>
  </view>
</view>
