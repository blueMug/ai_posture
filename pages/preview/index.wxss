.page {
  position: relative;
  width: 100vw;
  height: 100vh;
  overflow: hidden;
  background: #0d0d0d;
}

.photo {
  position: relative;
  z-index: 1;
  width: 100vw;
  height: 100vh;
}

.guide-preview {
  position: absolute;
  z-index: 2;
  opacity: 0.92;
}

.top-bar {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  z-index: 3;
  height: 160rpx;
  padding: 72rpx 32rpx 0;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: linear-gradient(180deg, rgba(0, 0, 0, 0.68), rgba(0, 0, 0, 0));
}

.title {
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 600;
}

.back-btn,
.placeholder {
  width: 112rpx;
}

.back-btn {
  height: 60rpx;
  line-height: 60rpx;
  border-radius: 30rpx;
  color: #ffffff;
  font-size: 26rpx;
  text-align: center;
  background: rgba(0, 0, 0, 0.62);
  border: 2rpx solid rgba(255, 255, 255, 0.62);
}

.guide-visibility-btn {
  width: 112rpx;
  height: 52rpx;
  line-height: 52rpx;
  padding: 0;
  margin: 0;
  border-radius: 26rpx;
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 600;
  text-align: center;
  background: rgba(0, 0, 0, 0.56);
  border: 1rpx solid rgba(255, 255, 255, 0.42);
  transform: translateY(108rpx);
}

.guide-visibility-btn.active {
  color: #111111;
  background: #ffe95c;
  border-color: #ffe95c;
}

.bottom-panel {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 3;
  padding: 36rpx 32rpx 56rpx;
  box-sizing: border-box;
  background: linear-gradient(0deg, rgba(0, 0, 0, 0.68), rgba(0, 0, 0, 0));
}

.share-card {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  padding: 22rpx;
  border-radius: 28rpx;
  box-sizing: border-box;
  background: rgba(18, 18, 18, 0.76);
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  backdrop-filter: blur(18rpx);
}

.share-copy {
  flex: 1;
  min-width: 0;
  padding-right: 18rpx;
  box-sizing: border-box;
}

.share-kicker {
  display: inline-flex;
  align-items: center;
  height: 34rpx;
  padding: 0 12rpx;
  border-radius: 999rpx;
  color: #111111;
  font-size: 19rpx;
  font-weight: 800;
  background: #ffe95c;
}

.share-title {
  margin-top: 10rpx;
  color: #ffffff;
  font-size: 28rpx;
  line-height: 1.3;
  font-weight: 800;
  display: -webkit-box;
  overflow: hidden;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.share-desc {
  margin-top: 8rpx;
  color: rgba(255, 255, 255, 0.72);
  font-size: 22rpx;
  line-height: 1.35;
  display: -webkit-box;
  overflow: hidden;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
}

.share-pose-btn {
  flex: 0 0 auto;
  width: 168rpx;
  height: 68rpx;
  margin: 0;
  padding: 0;
  border-radius: 999rpx;
  color: #111111;
  font-size: 24rpx;
  line-height: 68rpx;
  font-weight: 800;
  background: #ffe95c;
}

.save-btn,
.share-photo-btn {
  height: 92rpx;
  line-height: 92rpx;
  border-radius: 46rpx;
  color: #111111;
  font-size: 30rpx;
  font-weight: 600;
  background: #ffe95c;
}

.photo-actions {
  display: flex;
  align-items: center;
}

.photo-actions .save-btn,
.photo-actions .share-photo-btn {
  flex: 1;
  margin: 0;
}

.photo-actions .share-photo-btn {
  margin-right: 20rpx;
}

.confirm-actions {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.discard-btn,
.accept-btn {
  flex: 1;
  height: 92rpx;
  line-height: 92rpx;
  margin: 0;
  border-radius: 46rpx;
  font-size: 30rpx;
  font-weight: 600;
}

.discard-btn {
  color: #ffffff;
  background: rgba(255, 255, 255, 0.28);
}

.accept-btn {
  color: #111111;
  background: #ffe95c;
}

.confirm-actions .share-photo-btn {
  flex: 1;
  margin: 0;
  color: #ffffff;
  background: rgba(255, 255, 255, 0.22);
  border: 1rpx solid rgba(255, 255, 255, 0.36);
}

.guide-composer {
  position: fixed;
  left: 0;
  top: 0;
  z-index: 0;
  width: 1px;
  height: 1px;
  opacity: 0;
  pointer-events: none;
}

.save-btn::after,
.share-photo-btn::after,
.share-pose-btn::after,
.guide-visibility-btn::after,
.discard-btn::after,
.accept-btn::after {
  border: 0;
}
