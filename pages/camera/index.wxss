.page,
.camera {
  width: 100vw;
  height: 100vh;
}

.camera {
  display: block;
}

.top-bar {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  z-index: 10;
  height: 160rpx;
  padding: 72rpx 32rpx 0;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: linear-gradient(180deg, rgba(0, 0, 0, 0.45), rgba(0, 0, 0, 0));
}

.title {
  font-size: 34rpx;
  font-weight: 600;
  color: #ffffff;
}

.ghost-btn,
.small-btn,
.round-btn {
  color: #ffffff;
  background: rgba(0, 0, 0, 0.36);
  border: 1rpx solid rgba(255, 255, 255, 0.36);
  text-align: center;
}

.ghost-btn {
  min-width: 144rpx;
  height: 64rpx;
  line-height: 64rpx;
  border-radius: 32rpx;
  font-size: 24rpx;
}

.top-placeholder {
  width: 144rpx;
  height: 64rpx;
}

.pose-stage {
  position: absolute;
  left: 7vw;
  right: 7vw;
  top: 13vh;
  bottom: 21vh;
  z-index: 5;
}

.pose-name {
  position: absolute;
  left: 50%;
  top: 0;
  transform: translateX(-50%);
  padding: 12rpx 28rpx;
  border-radius: 999rpx;
  color: rgba(255, 255, 255, 0.92);
  font-size: 26rpx;
  font-weight: 600;
  background: rgba(0, 0, 0, 0.24);
  border: 1rpx solid rgba(255, 255, 255, 0.24);
}

.pose-guide-image {
  width: 100%;
  height: 100%;
  opacity: 0.92;
}

.pose-guide-box {
  position: absolute;
  z-index: 6;
}

.guide-help {
  position: absolute;
  left: 50%;
  bottom: 230rpx;
  transform: translateX(-50%);
  z-index: 7;
  padding: 10rpx 22rpx;
  border-radius: 999rpx;
  color: rgba(255, 255, 255, 0.82);
  font-size: 22rpx;
  background: rgba(0, 0, 0, 0.26);
}

.guide-presets {
  position: absolute;
  left: 50%;
  bottom: 164rpx;
  transform: translateX(-50%);
  z-index: 8;
  display: flex;
  align-items: center;
}

.guide-preset-btn {
  width: 76rpx;
  height: 52rpx;
  line-height: 52rpx;
  border-radius: 26rpx;
  color: #ffffff;
  font-size: 21rpx;
  text-align: center;
  background: rgba(0, 0, 0, 0.34);
  border: 1rpx solid rgba(255, 255, 255, 0.34);
}

.guide-preset-btn + .guide-preset-btn {
  margin-left: 8rpx;
}

.guide-tools {
  position: absolute;
  left: 50%;
  bottom: 104rpx;
  transform: translateX(-50%);
  z-index: 8;
  display: flex;
  align-items: center;
}

.guide-tool-btn {
  width: 60rpx;
  height: 52rpx;
  line-height: 52rpx;
  border-radius: 26rpx;
  color: #ffffff;
  font-size: 28rpx;
  text-align: center;
  background: rgba(0, 0, 0, 0.34);
  border: 1rpx solid rgba(255, 255, 255, 0.34);
}

.guide-tool-btn + .guide-tool-btn {
  margin-left: 12rpx;
}

.guide-tool-btn.reset {
  width: 104rpx;
  font-size: 22rpx;
}

.guide-move-tools {
  position: absolute;
  left: 50%;
  bottom: 0;
  transform: translateX(-50%);
  z-index: 8;
}

.guide-move-row {
  display: flex;
  align-items: center;
  justify-content: center;
}

.guide-move-row + .guide-move-row {
  margin-top: 8rpx;
}

.guide-move-btn {
  width: 58rpx;
  height: 44rpx;
  line-height: 44rpx;
  margin: 0 5rpx;
  border-radius: 22rpx;
  color: #ffffff;
  font-size: 20rpx;
  text-align: center;
  background: rgba(0, 0, 0, 0.34);
  border: 1rpx solid rgba(255, 255, 255, 0.34);
}

.guide-move-btn.placeholder {
  opacity: 0;
}

.bottom-panel {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 10;
  padding: 28rpx 28rpx 44rpx;
  box-sizing: border-box;
  background: linear-gradient(0deg, rgba(0, 0, 0, 0.62), rgba(0, 0, 0, 0));
}

.template-switch {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 28rpx;
}

.round-btn {
  width: 136rpx;
  height: 60rpx;
  line-height: 60rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
}

.template-text {
  flex: 1;
  padding: 0 20rpx;
  color: rgba(255, 255, 255, 0.88);
  font-size: 24rpx;
  text-align: center;
}

.shoot-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.shutter-group {
  display: flex;
  align-items: center;
}

.switch-icon-btn {
  width: 72rpx;
  height: 72rpx;
  line-height: 72rpx;
  margin-left: 22rpx;
  border-radius: 999rpx;
  color: #ffffff;
  font-size: 40rpx;
  text-align: center;
  background: rgba(0, 0, 0, 0.38);
  border: 1rpx solid rgba(255, 255, 255, 0.36);
}

.confirm-toggle {
  width: 288rpx;
  height: 56rpx;
  margin: 22rpx auto 0;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: rgba(255, 255, 255, 0.78);
  font-size: 23rpx;
  background: rgba(0, 0, 0, 0.34);
  border: 1rpx solid rgba(255, 255, 255, 0.28);
}

.confirm-toggle.active {
  color: #111111;
  background: #ffe95c;
  border-color: #ffe95c;
}

.toggle-dot {
  width: 16rpx;
  height: 16rpx;
  margin-right: 12rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.56);
}

.confirm-toggle.active .toggle-dot {
  background: #111111;
}

.small-btn {
  width: 152rpx;
  height: 58rpx;
  line-height: 58rpx;
  border-radius: 29rpx;
  font-size: 24rpx;
}

.shutter {
  width: 132rpx;
  height: 132rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.28);
  display: flex;
  align-items: center;
  justify-content: center;
}

.shutter-inner {
  width: 104rpx;
  height: 104rpx;
  border-radius: 999rpx;
  background: #ffffff;
}
