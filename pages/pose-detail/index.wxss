.page {
  min-height: 100vh;
  padding: 88rpx 28rpx 180rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at 22% 8%, rgba(255, 233, 92, 0.24), transparent 34%),
    radial-gradient(circle at 86% 18%, rgba(156, 231, 255, 0.18), transparent 36%),
    linear-gradient(180deg, #171717 0%, #090909 100%);
}

.top-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 72rpx;
}

.back-btn,
.placeholder {
  width: 108rpx;
}

.back-btn {
  color: rgba(255, 255, 255, 0.86);
  font-size: 26rpx;
}

.title {
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
}

.content {
  margin-top: 26rpx;
}

.copy {
  padding: 0 8rpx 24rpx;
}

.pose-name {
  color: #ffffff;
  font-size: 46rpx;
  line-height: 1.18;
  font-weight: 800;
}

.photo-card {
  position: relative;
  height: 900rpx;
  max-height: 66vh;
  border-radius: 42rpx;
  overflow: hidden;
  border: 1rpx solid rgba(255, 255, 255, 0.24);
  box-shadow: 0 28rpx 80rpx rgba(0, 0, 0, 0.34);
}

.photo-glow {
  position: absolute;
  left: -80rpx;
  top: -120rpx;
  width: 320rpx;
  height: 320rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.32);
}

.pose-photo {
  position: absolute;
  left: 28rpx;
  right: 28rpx;
  top: 28rpx;
  bottom: 28rpx;
  z-index: 2;
  width: calc(100% - 56rpx);
  height: calc(100% - 56rpx);
}

.image-loading {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 4;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.28);
}

.loading-spinner {
  width: 58rpx;
  height: 58rpx;
  border-radius: 999rpx;
  border: 6rpx solid rgba(255, 255, 255, 0.22);
  border-top-color: #ffe95c;
  animation: image-loading-spin 0.8s linear infinite;
}

.loading-text {
  margin-top: 18rpx;
  color: rgba(255, 255, 255, 0.86);
  font-size: 24rpx;
  font-weight: 700;
}

@keyframes image-loading-spin {
  from {
    transform: rotate(0deg);
  }

  to {
    transform: rotate(360deg);
  }
}

.image-error {
  position: absolute;
  left: 50%;
  top: 50%;
  z-index: 5;
  transform: translate(-50%, -50%);
  width: 360rpx;
  padding: 18rpx 24rpx;
  border-radius: 24rpx;
  color: rgba(255, 255, 255, 0.92);
  font-size: 25rpx;
  font-weight: 700;
  text-align: center;
  background: rgba(0, 0, 0, 0.66);
}

.image-note {
  display: flex;
  align-items: flex-start;
  margin-top: 22rpx;
  padding: 20rpx 24rpx;
  border-radius: 28rpx;
  box-sizing: border-box;
  background: rgba(255, 233, 92, 0.12);
  border: 1rpx solid rgba(255, 233, 92, 0.24);
}

.image-note-label {
  flex: none;
  margin-right: 18rpx;
  color: rgba(255, 233, 92, 0.94);
  font-size: 24rpx;
  font-weight: 900;
}

.image-note-text {
  flex: 1;
  min-width: 0;
  color: rgba(255, 255, 255, 0.86);
  font-size: 25rpx;
  line-height: 1.45;
}

.action-card,
.detail-card {
  margin-top: 26rpx;
  padding: 26rpx;
  border-radius: 34rpx;
  box-sizing: border-box;
  background: rgba(255, 255, 255, 0.13);
  border: 1rpx solid rgba(255, 255, 255, 0.22);
  box-shadow: 0 24rpx 70rpx rgba(0, 0, 0, 0.24);
}

.photographer-card {
  display: flex;
  align-items: center;
  margin-top: 24rpx;
  padding: 24rpx;
  border-radius: 34rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at 12% 0%, rgba(255, 233, 92, 0.24), transparent 46%),
    rgba(255, 255, 255, 0.12);
  border: 1rpx solid rgba(255, 233, 92, 0.28);
  box-shadow: 0 22rpx 62rpx rgba(0, 0, 0, 0.22);
}

.photographer-copy {
  flex: 1;
  min-width: 0;
  padding-right: 18rpx;
  box-sizing: border-box;
}

.photographer-kicker {
  display: inline-flex;
  align-items: center;
  height: 34rpx;
  padding: 0 12rpx;
  border-radius: 999rpx;
  color: #111111;
  font-size: 20rpx;
  font-weight: 900;
  background: #ffe95c;
}

.photographer-title {
  margin-top: 12rpx;
  color: #ffffff;
  font-size: 30rpx;
  line-height: 1.3;
  font-weight: 900;
}

.photographer-desc {
  margin-top: 8rpx;
  color: rgba(255, 255, 255, 0.72);
  font-size: 23rpx;
  line-height: 1.42;
}

.photographer-share-btn {
  flex: none;
  width: 168rpx;
  height: 72rpx;
  line-height: 72rpx;
  margin: 0;
  padding: 0;
  border-radius: 999rpx;
  color: #111111;
  font-size: 24rpx;
  font-weight: 900;
  background: #ffe95c;
}

.section-title {
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 900;
}

.action-list {
  margin-top: 16rpx;
}

.action-item {
  display: flex;
  align-items: flex-start;
  padding: 12rpx 0;
}

.action-dot {
  flex: none;
  width: 12rpx;
  height: 12rpx;
  margin: 13rpx 18rpx 0 0;
  border-radius: 999rpx;
  background: #ffe95c;
}

.action-text {
  flex: 1;
  min-width: 0;
  color: rgba(255, 255, 255, 0.88);
  font-size: 26rpx;
  line-height: 1.45;
  font-weight: 700;
  white-space: normal;
  word-break: break-word;
  overflow: visible;
}

.detail-card {
  margin-top: 22rpx;
  background: rgba(255, 255, 255, 0.08);
}

.detail-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.detail-toggle {
  color: rgba(255, 233, 92, 0.94);
  font-size: 24rpx;
  font-weight: 800;
}

.guide-list {
  margin-top: 18rpx;
}

.guide-item {
  display: block;
  padding: 16rpx 0;
  border-top: 1rpx solid rgba(255, 255, 255, 0.12);
}

.guide-label {
  display: inline-block;
  margin-bottom: 14rpx;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  color: rgba(255, 255, 255, 0.56);
  font-size: 23rpx;
  font-weight: 800;
  background: rgba(255, 255, 255, 0.07);
}

.guide-content {
  width: 100%;
  min-width: 0;
}

.guide-text {
  color: rgba(255, 255, 255, 0.82);
  font-size: 24rpx;
  line-height: 1.48;
}

.guide-section {
  padding: 18rpx 20rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.07);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.guide-section + .guide-section {
  margin-top: 16rpx;
}

.guide-section.highlight {
  background: rgba(255, 233, 92, 0.1);
  border-color: rgba(255, 233, 92, 0.22);
}

.guide-section-title {
  display: inline-block;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  color: rgba(255, 233, 92, 0.94);
  font-size: 21rpx;
  font-weight: 900;
  background: rgba(255, 233, 92, 0.12);
}

.guide-section-lines {
  margin-top: 12rpx;
}

.guide-section-line {
  display: flex;
  align-items: flex-start;
}

.guide-section-line + .guide-section-line {
  margin-top: 10rpx;
}

.guide-section-dot {
  flex: none;
  width: 8rpx;
  height: 8rpx;
  margin: 13rpx 14rpx 0 0;
  border-radius: 999rpx;
  background: rgba(255, 233, 92, 0.86);
}

.guide-section-text {
  flex: 1;
  min-width: 0;
  color: rgba(255, 255, 255, 0.84);
  font-size: 24rpx;
  line-height: 1.5;
  word-break: break-word;
}

.guide-item.avoid .guide-text {
  color: rgba(255, 255, 255, 0.64);
}

.preload-guide-image {
  position: fixed;
  left: -4px;
  top: -4px;
  width: 1px;
  height: 1px;
  opacity: 0;
  pointer-events: none;
}

.bottom-panel {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 10;
  padding: 22rpx 32rpx 30rpx;
  box-sizing: border-box;
  display: flex;
  gap: 20rpx;
  background: linear-gradient(180deg, rgba(9, 9, 9, 0), rgba(9, 9, 9, 0.94) 28%);
}

.share-btn,
.favorite-btn,
.shoot-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 96rpx;
  padding: 0;
  border-radius: 999rpx;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1;
}

.share-btn {
  color: #ffffff;
  background: rgba(255, 255, 255, 0.18);
  border: 1rpx solid rgba(255, 255, 255, 0.36);
}

.favorite-btn {
  color: #ffffff;
  background: rgba(255, 255, 255, 0.18);
  border: 1rpx solid rgba(255, 255, 255, 0.36);
}

.favorite-btn.active {
  color: #111111;
  background: #ffe95c;
  border-color: #ffe95c;
}

.shoot-btn {
  color: #111111;
  background: #ffe95c;
}

.share-btn::after,
.favorite-btn::after,
.shoot-btn::after,
.photographer-share-btn::after {
  border: 0;
}
