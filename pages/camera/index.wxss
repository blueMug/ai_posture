.page {
  width: 100vw;
  height: 100vh;
  overflow: hidden;
  background: #000000;
}

.camera {
  width: 100vw;
  height: calc(100vh - 330rpx);
}

.camera {
  display: block;
}

.privacy-wait {
  width: 100vw;
  height: 100vh;
  padding: 220rpx 48rpx 0;
  box-sizing: border-box;
  text-align: center;
  background:
    radial-gradient(circle at 18% 8%, rgba(255, 233, 92, 0.24), transparent 34%),
    linear-gradient(180deg, #171717 0%, #090909 100%);
}

.privacy-title {
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 900;
}

.privacy-desc {
  margin-top: 20rpx;
  color: rgba(255, 255, 255, 0.76);
  font-size: 25rpx;
  line-height: 1.5;
}

.pose-stage {
  position: absolute;
  left: 7vw;
  right: 7vw;
  top: 8vh;
  bottom: 4vh;
  z-index: 5;
}

.pose-guide-layer {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  transform-origin: center center;
}

.camera-settings {
  position: absolute;
  left: 28rpx;
  top: 88rpx;
  z-index: 14;
}

.settings-trigger {
  width: 72rpx;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 999rpx;
  color: #ffffff;
  font-size: 36rpx;
  font-weight: 800;
  text-align: center;
  background: rgba(0, 0, 0, 0.62);
  border: 2rpx solid rgba(255, 255, 255, 0.58);
}

.settings-trigger.active {
  color: #111111;
  background: #ffe95c;
  border-color: #ffe95c;
}

.settings-panel {
  width: 360rpx;
  margin-top: 14rpx;
  padding: 22rpx;
  border-radius: 28rpx;
  box-sizing: border-box;
  background: rgba(0, 0, 0, 0.72);
  border: 2rpx solid rgba(255, 255, 255, 0.42);
}

.settings-title {
  color: rgba(255, 255, 255, 0.92);
  font-size: 24rpx;
  font-weight: 900;
}

.settings-item {
  margin-top: 18rpx;
}

.settings-label {
  color: rgba(255, 255, 255, 0.72);
  font-size: 22rpx;
  font-weight: 700;
}

.scale-control {
  display: flex;
  align-items: center;
  margin-top: 12rpx;
}

.scale-step-btn,
.scale-percent {
  height: 58rpx;
  line-height: 58rpx;
  border-radius: 999rpx;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 900;
  text-align: center;
  background: rgba(255, 255, 255, 0.14);
  border: 2rpx solid rgba(255, 255, 255, 0.36);
}

.scale-step-btn {
  width: 72rpx;
}

.scale-percent {
  width: 124rpx;
  margin: 0 12rpx;
  color: #ffe95c;
  font-size: 24rpx;
}

.settings-actions {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  margin-top: 18rpx;
}

.settings-chip {
  height: 56rpx;
  line-height: 56rpx;
  padding: 0 22rpx;
  margin: 0 12rpx 12rpx 0;
  border-radius: 999rpx;
  color: rgba(255, 255, 255, 0.9);
  font-size: 22rpx;
  font-weight: 800;
  background: rgba(255, 255, 255, 0.12);
  border: 2rpx solid rgba(255, 255, 255, 0.34);
}

.settings-chip.active {
  color: #111111;
  background: #ffe95c;
  border-color: #ffe95c;
}

.guide-usage-tip {
  position: absolute;
  left: 50%;
  top: 190rpx;
  z-index: 15;
  transform: translateX(-50%);
  width: 520rpx;
  padding: 20rpx 24rpx;
  border-radius: 28rpx;
  box-sizing: border-box;
  text-align: center;
  background: rgba(0, 0, 0, 0.72);
  border: 2rpx solid rgba(255, 233, 92, 0.58);
  box-shadow: 0 18rpx 46rpx rgba(0, 0, 0, 0.34);
}

.guide-usage-title {
  color: #ffe95c;
  font-size: 26rpx;
  font-weight: 900;
}

.guide-usage-desc {
  margin-top: 8rpx;
  color: rgba(255, 255, 255, 0.88);
  font-size: 22rpx;
  font-weight: 700;
}

.pose-name {
  position: absolute;
  left: 96rpx;
  top: 0;
  max-width: 360rpx;
  padding: 10rpx 22rpx;
  border-radius: 999rpx;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 800;
  background: rgba(0, 0, 0, 0.5);
  border: 1rpx solid rgba(255, 255, 255, 0.32);
  text-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.85);
}

.pose-guide-image {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
}

.pose-guide-main {
  z-index: 3;
}

.pose-guide-boost {
  z-index: 2;
  opacity: 0.88;
}

.pose-guide-shadow {
  z-index: 1;
  opacity: 0.72;
  filter: brightness(0);
  transform: translate3d(6rpx, 6rpx, 0);
}

.outline-guide-image {
  opacity: 1;
}

.photo-guide-image {
  opacity: 0.42;
}

.pose-guide-box {
  position: absolute;
  left: 0;
  top: 8%;
  z-index: 6;
  width: 100%;
  height: 88%;
}

.guide-error-tip {
  position: absolute;
  left: 50%;
  top: 50%;
  z-index: 8;
  transform: translate(-50%, -50%);
  padding: 14rpx 24rpx;
  border-radius: 999rpx;
  color: rgba(255, 255, 255, 0.92);
  font-size: 24rpx;
  background: rgba(0, 0, 0, 0.72);
  border: 1rpx solid rgba(255, 255, 255, 0.48);
}

.bottom-panel {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 20;
  min-height: 330rpx;
  padding: 24rpx 28rpx 38rpx;
  box-sizing: border-box;
  background:
    linear-gradient(0deg, rgba(0, 0, 0, 0.94), rgba(0, 0, 0, 0.82)),
    #000000;
}

.countdown-mask {
  position: absolute;
  right: 28rpx;
  top: 178rpx;
  z-index: 12;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 12rpx 22rpx;
  border-radius: 999rpx;
  background: rgba(0, 0, 0, 0.42);
  border: 1rpx solid rgba(255, 255, 255, 0.42);
  box-shadow: 0 12rpx 34rpx rgba(0, 0, 0, 0.32);
}

.countdown-number {
  min-width: 66rpx;
  height: 66rpx;
  line-height: 66rpx;
  border-radius: 999rpx;
  color: #ffe95c;
  font-size: 48rpx;
  font-weight: 900;
  text-align: center;
  background: rgba(255, 233, 92, 0.16);
  text-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.55);
}

.shoot-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.guide-toggle-btn,
.select-pose-btn {
  width: 84rpx;
  height: 84rpx;
}

.guide-toggle-btn {
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  background: rgba(0, 0, 0, 0.62);
  border: 2rpx solid rgba(255, 255, 255, 0.62);
}

.guide-toggle-btn.active {
  background: rgba(255, 233, 92, 0.3);
  border-color: #ffe95c;
}

.guide-toggle-btn.muted {
  opacity: 0.72;
}

.model-toggle-btn {
  position: relative;
  width: 92rpx;
  height: 92rpx;
  background: rgba(255, 255, 255, 0.14);
  border-width: 3rpx;
  box-shadow: 0 10rpx 28rpx rgba(0, 0, 0, 0.26);
}

.model-toggle-image {
  width: 100%;
  height: 100%;
  display: block;
}

.model-toggle-mask {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 34rpx;
  line-height: 34rpx;
  color: rgba(255, 255, 255, 0.94);
  font-size: 18rpx;
  text-align: center;
  background: rgba(0, 0, 0, 0.72);
}

.select-pose-btn {
  width: 108rpx;
  height: 68rpx;
  line-height: 68rpx;
  border-radius: 999rpx;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 700;
  text-align: center;
  background: rgba(0, 0, 0, 0.62);
  border: 2rpx solid rgba(255, 255, 255, 0.62);
}

.eye-icon {
  position: relative;
  width: 44rpx;
  height: 28rpx;
  border: 4rpx solid #ffffff;
  border-radius: 50%;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
}

.eye-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #ffffff;
}

.eye-slash {
  position: absolute;
  left: 18rpx;
  top: -10rpx;
  width: 5rpx;
  height: 48rpx;
  border-radius: 999rpx;
  background: #ffffff;
  transform: rotate(45deg);
}

.shutter-group {
  display: flex;
  align-items: center;
}

.switch-icon-btn {
  width: 72rpx;
  height: 72rpx;
  line-height: 72rpx;
  margin-left: 22rpx;
  border-radius: 999rpx;
  color: #ffffff;
  font-size: 40rpx;
  text-align: center;
  background: rgba(0, 0, 0, 0.62);
  border: 2rpx solid rgba(255, 255, 255, 0.62);
}

.camera-zoom-row {
  width: 590rpx;
  height: 72rpx;
  margin: 22rpx auto 0;
  padding: 0 20rpx;
  border-radius: 36rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: rgba(0, 0, 0, 0.62);
  border: 2rpx solid rgba(255, 255, 255, 0.48);
}

.zoom-slider {
  flex: 1;
  margin: 0 10rpx;
}

.zoom-label {
  width: 64rpx;
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 700;
  text-align: center;
}

.shutter {
  width: 132rpx;
  height: 132rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.28);
  display: flex;
  align-items: center;
  justify-content: center;
}

.shutter-inner {
  width: 104rpx;
  height: 104rpx;
  border-radius: 999rpx;
  background: #ffffff;
}
