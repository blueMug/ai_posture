.page {
  min-height: 100vh;
  padding: 92rpx 28rpx 56rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at 18% 8%, rgba(255, 233, 92, 0.28), transparent 34%),
    radial-gradient(circle at 84% 18%, rgba(156, 231, 255, 0.24), transparent 36%),
    linear-gradient(180deg, #171717 0%, #0d0d0d 56%, #080808 100%);
}

.hero {
  padding: 28rpx 8rpx 38rpx;
}

.eyebrow {
  display: inline-block;
  padding: 10rpx 18rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.18);
  border-radius: 999rpx;
  color: rgba(255, 255, 255, 0.72);
  font-size: 22rpx;
  letter-spacing: 1rpx;
  background: rgba(255, 255, 255, 0.08);
}

.title {
  margin-top: 28rpx;
  color: #ffffff;
  font-size: 58rpx;
  line-height: 1.08;
  font-weight: 800;
  letter-spacing: -1rpx;
}

.subtitle {
  margin-top: 22rpx;
  width: 640rpx;
  max-width: 100%;
  color: rgba(255, 255, 255, 0.68);
  font-size: 27rpx;
  line-height: 1.6;
}

.category {
  margin-top: 36rpx;
}

.category-head {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  margin-bottom: 20rpx;
  padding: 0 6rpx;
}

.category-title {
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 700;
}

.category-subtitle {
  margin-top: 8rpx;
  color: rgba(255, 255, 255, 0.5);
  font-size: 23rpx;
}

.category-count {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  color: rgba(255, 255, 255, 0.74);
  font-size: 22rpx;
  background: rgba(255, 255, 255, 0.08);
}

.pose-list {
  display: flex;
  flex-direction: column;
}

.pose-card {
  display: flex;
  min-height: 248rpx;
  margin-bottom: 24rpx;
  padding: 18rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 36rpx;
  box-sizing: border-box;
  background: rgba(255, 255, 255, 0.08);
  box-shadow: 0 24rpx 70rpx rgba(0, 0, 0, 0.28);
  overflow: hidden;
}

.preview {
  position: relative;
  flex: 0 0 210rpx;
  height: 212rpx;
  border-radius: 28rpx;
  overflow: hidden;
}

.preview-shine {
  position: absolute;
  left: -40rpx;
  top: -70rpx;
  width: 190rpx;
  height: 190rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.34);
}

.mini-stage {
  position: absolute;
  left: 16rpx;
  right: 16rpx;
  top: 18rpx;
  bottom: 16rpx;
}

.mini-guide-image {
  position: absolute;
  left: 0;
  top: 0;
  z-index: 2;
  width: 100%;
  height: 100%;
  opacity: 0.96;
}

.badge {
  position: absolute;
  right: 14rpx;
  bottom: 14rpx;
  z-index: 3;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  color: rgba(0, 0, 0, 0.72);
  font-size: 21rpx;
  font-weight: 700;
  background: rgba(255, 255, 255, 0.72);
}

.pose-info {
  flex: 1;
  min-width: 0;
  padding: 8rpx 4rpx 4rpx 24rpx;
  box-sizing: border-box;
}

.pose-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.pose-name {
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 700;
}

.pose-action {
  flex: 0 0 auto;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  color: #111111;
  font-size: 22rpx;
  font-weight: 700;
  background: #ffe95c;
}

.pose-tip {
  margin-top: 16rpx;
  color: rgba(255, 233, 92, 0.92);
  font-size: 24rpx;
}

.pose-desc {
  margin-top: 12rpx;
  color: rgba(255, 255, 255, 0.58);
  font-size: 24rpx;
  line-height: 1.45;
}
