.page {
  min-height: 100vh;
  padding: 88rpx 28rpx 180rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at 22% 8%, rgba(255, 233, 92, 0.24), transparent 34%),
    radial-gradient(circle at 86% 18%, rgba(156, 231, 255, 0.18), transparent 36%),
    linear-gradient(180deg, #171717 0%, #090909 100%);
}

.top-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 72rpx;
}

.back-btn,
.placeholder {
  width: 108rpx;
}

.back-btn {
  color: rgba(255, 255, 255, 0.86);
  font-size: 26rpx;
}

.title {
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
}

.content {
  margin-top: 26rpx;
}

.copy {
  padding: 0 8rpx 24rpx;
}

.pose-name {
  color: #ffffff;
  font-size: 46rpx;
  line-height: 1.18;
  font-weight: 800;
}

.photo-card {
  position: relative;
  height: 900rpx;
  max-height: 66vh;
  border-radius: 42rpx;
  overflow: hidden;
  border: 1rpx solid rgba(255, 255, 255, 0.24);
  box-shadow: 0 28rpx 80rpx rgba(0, 0, 0, 0.34);
}

.photo-glow {
  position: absolute;
  left: -80rpx;
  top: -120rpx;
  width: 320rpx;
  height: 320rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.32);
}

.pose-photo {
  position: absolute;
  left: 28rpx;
  right: 28rpx;
  top: 28rpx;
  bottom: 84rpx;
  z-index: 2;
  width: calc(100% - 56rpx);
  height: calc(100% - 112rpx);
}

.tap-tip {
  position: absolute;
  left: 50%;
  bottom: 28rpx;
  z-index: 3;
  transform: translateX(-50%);
  padding: 12rpx 22rpx;
  border-radius: 999rpx;
  color: rgba(255, 255, 255, 0.9);
  font-size: 23rpx;
  font-weight: 700;
  background: rgba(0, 0, 0, 0.66);
}

.image-note {
  display: flex;
  align-items: flex-start;
  margin-top: 22rpx;
  padding: 20rpx 24rpx;
  border-radius: 28rpx;
  box-sizing: border-box;
  background: rgba(255, 233, 92, 0.12);
  border: 1rpx solid rgba(255, 233, 92, 0.24);
}

.image-note-label {
  flex: none;
  margin-right: 18rpx;
  color: rgba(255, 233, 92, 0.94);
  font-size: 24rpx;
  font-weight: 900;
}

.image-note-text {
  flex: 1;
  min-width: 0;
  color: rgba(255, 255, 255, 0.86);
  font-size: 25rpx;
  line-height: 1.45;
}

.action-card,
.detail-card {
  margin-top: 26rpx;
  padding: 26rpx;
  border-radius: 34rpx;
  box-sizing: border-box;
  background: rgba(255, 255, 255, 0.13);
  border: 1rpx solid rgba(255, 255, 255, 0.22);
  box-shadow: 0 24rpx 70rpx rgba(0, 0, 0, 0.24);
}

.section-title {
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 900;
}

.action-list {
  margin-top: 16rpx;
}

.action-item {
  display: flex;
  align-items: flex-start;
  padding: 12rpx 0;
}

.action-dot {
  flex: none;
  width: 12rpx;
  height: 12rpx;
  margin: 13rpx 18rpx 0 0;
  border-radius: 999rpx;
  background: #ffe95c;
}

.action-text {
  flex: 1;
  min-width: 0;
  color: rgba(255, 255, 255, 0.88);
  font-size: 26rpx;
  line-height: 1.45;
  font-weight: 700;
  white-space: normal;
  word-break: break-word;
  overflow: visible;
}

.detail-card {
  margin-top: 22rpx;
  background: rgba(255, 255, 255, 0.08);
}

.detail-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.detail-toggle {
  color: rgba(255, 233, 92, 0.94);
  font-size: 24rpx;
  font-weight: 800;
}

.guide-list {
  margin-top: 18rpx;
}

.guide-item {
  display: flex;
  padding: 16rpx 0;
  border-top: 1rpx solid rgba(255, 255, 255, 0.12);
}

.guide-label {
  flex: 0 0 78rpx;
  color: rgba(255, 255, 255, 0.56);
  font-size: 23rpx;
  font-weight: 800;
}

.guide-text {
  flex: 1;
  min-width: 0;
  color: rgba(255, 255, 255, 0.82);
  font-size: 24rpx;
  line-height: 1.48;
}

.guide-item.avoid .guide-text {
  color: rgba(255, 255, 255, 0.64);
}

.preload-guide-image {
  position: fixed;
  left: -4px;
  top: -4px;
  width: 1px;
  height: 1px;
  opacity: 0;
  pointer-events: none;
}

.bottom-panel {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 10;
  padding: 22rpx 32rpx 30rpx;
  box-sizing: border-box;
  display: flex;
  gap: 20rpx;
  background: linear-gradient(180deg, rgba(9, 9, 9, 0), rgba(9, 9, 9, 0.94) 28%);
}

.share-btn,
.favorite-btn,
.shoot-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 96rpx;
  padding: 0;
  border-radius: 999rpx;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1;
}

.share-btn {
  color: #ffffff;
  background: rgba(255, 255, 255, 0.18);
  border: 1rpx solid rgba(255, 255, 255, 0.36);
}

.favorite-btn {
  color: #ffffff;
  background: rgba(255, 255, 255, 0.18);
  border: 1rpx solid rgba(255, 255, 255, 0.36);
}

.favorite-btn.active {
  color: #111111;
  background: #ffe95c;
  border-color: #ffe95c;
}

.shoot-btn {
  color: #111111;
  background: #ffe95c;
}

.share-btn::after,
.favorite-btn::after,
.shoot-btn::after {
  border: 0;
}
