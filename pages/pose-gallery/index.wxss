.page {
  min-height: 100vh;
  padding: 72rpx 24rpx 160rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at 18% 6%, rgba(255, 233, 92, 0.22), transparent 34%),
    radial-gradient(circle at 88% 16%, rgba(156, 231, 255, 0.18), transparent 36%),
    linear-gradient(180deg, #171717 0%, #090909 100%);
}

.top-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 72rpx;
}

.placeholder {
  width: 108rpx;
}

.title {
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
}

.search-card {
  margin-top: 22rpx;
  height: 88rpx;
  padding: 0 24rpx;
  border-radius: 28rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.1);
  border: 1rpx solid rgba(255, 255, 255, 0.12);
}

.search-icon {
  margin-right: 14rpx;
  color: rgba(255, 255, 255, 0.64);
  font-size: 34rpx;
}

.search-input {
  flex: 1;
  min-width: 0;
  height: 88rpx;
  color: #ffffff;
  font-size: 26rpx;
}

.search-placeholder {
  color: rgba(255, 255, 255, 0.42);
}

.search-clear {
  flex: 0 0 auto;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  color: #111111;
  font-size: 22rpx;
  font-weight: 700;
  background: #ffe95c;
}

.empty-state {
  margin-top: 28rpx;
  padding: 34rpx 28rpx;
  border-radius: 30rpx;
  text-align: center;
  background: rgba(255, 255, 255, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.empty-title {
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
}

.empty-desc {
  margin-top: 12rpx;
  color: rgba(255, 255, 255, 0.56);
  font-size: 24rpx;
}

.category-nav {
  margin-top: 22rpx;
  white-space: nowrap;
}

.category-nav-inner {
  display: inline-flex;
  align-items: center;
  padding-right: 24rpx;
}

.category-nav-chip {
  flex: 0 0 auto;
  height: 62rpx;
  line-height: 62rpx;
  margin-right: 14rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  box-sizing: border-box;
  color: rgba(255, 255, 255, 0.74);
  font-size: 24rpx;
  font-weight: 700;
  background: rgba(255, 255, 255, 0.09);
  border: 1rpx solid rgba(255, 255, 255, 0.12);
}

.category-nav-chip.active {
  color: #111111;
  background: #ffe95c;
  border-color: #ffe95c;
}

.category-nav-count {
  margin-left: 8rpx;
  font-size: 20rpx;
  opacity: 0.66;
}

.category {
  margin-top: 34rpx;
}

.category-head {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  margin-bottom: 18rpx;
  padding: 0 4rpx;
}

.category-title {
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 800;
}

.category-subtitle {
  margin-top: 8rpx;
  color: rgba(255, 255, 255, 0.48);
  font-size: 22rpx;
}

.photo-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.photo-card {
  position: relative;
  width: calc((100vw - 68rpx) / 2);
  height: 420rpx;
  margin-bottom: 20rpx;
  border-radius: 30rpx;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  box-shadow: 0 18rpx 50rpx rgba(0, 0, 0, 0.26);
}

.pose-photo {
  width: 100%;
  height: 100%;
  display: block;
}

.image-error {
  position: absolute;
  left: 18rpx;
  right: 18rpx;
  top: 50%;
  z-index: 3;
  transform: translateY(-50%);
  padding: 12rpx;
  border-radius: 18rpx;
  color: rgba(255, 255, 255, 0.88);
  font-size: 22rpx;
  text-align: center;
  background: rgba(0, 0, 0, 0.42);
}

.photo-info {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 4;
  min-height: 92rpx;
  padding: 26rpx 16rpx 16rpx;
  box-sizing: border-box;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  background: linear-gradient(180deg, rgba(0, 0, 0, 0), rgba(0, 0, 0, 0.72));
}

.pose-name {
  flex: 1;
  min-width: 0;
  padding-right: 12rpx;
  color: #ffffff;
  font-size: 24rpx;
  line-height: 1.25;
  font-weight: 800;
}

.shoot-chip {
  flex: 0 0 auto;
  width: 56rpx;
  height: 56rpx;
  line-height: 56rpx;
  border-radius: 999rpx;
  color: #111111;
  font-size: 24rpx;
  font-weight: 900;
  text-align: center;
  background: #ffe95c;
}
