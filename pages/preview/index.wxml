<view class="page">
  <image class="photo" src="{{photoPath}}" mode="aspectFit"></image>
  <image
    wx:if="{{confirmWithGuide && guidePreviewVisible && guideImage && guideStyleReady}}"
    class="guide-preview"
    src="{{guideImage}}"
    mode="scaleToFill"
    style="{{guideStyle}}"
  ></image>

  <view class="top-bar">
    <button
      wx:if="{{confirmWithGuide}}"
      class="back-btn guide-visibility-btn {{guidePreviewVisible ? 'active' : ''}}"
      bindtap="toggleGuidePreview"
    >{{guidePreviewVisible ? '关轮廓' : '开轮廓'}}</button>
    <view wx:else class="back-btn" bindtap="retake">重拍</view>
    <view class="title">{{confirmWithGuide ? '确认轮廓' : '照片预览'}}</view>
    <view class="placeholder"></view>
  </view>

  <view wx:if="{{confirmWithGuide}}" class="bottom-panel safe-area-bottom">
    <view class="hint">确认轮廓对齐后保存原照片，也可以分享带轮廓版本。</view>
    <button
      class="share-guide-btn"
      loading="{{shareGenerating}}"
      bindtap="sharePhotoWithGuide"
    >{{shareGenerating ? '生成中' : '分享带轮廓'}}</button>
    <view class="confirm-actions">
      <button class="discard-btn" bindtap="retake">放弃</button>
      <button class="accept-btn" bindtap="acceptPhoto">接受</button>
    </view>
  </view>

  <view wx:else class="bottom-panel safe-area-bottom">
    <view class="hint">轮廓不会出现在照片里。</view>
    <button class="save-btn" bindtap="savePhoto">保存到相册</button>
  </view>

  <canvas
    class="share-canvas"
    canvas-id="shareCanvas"
    style="width: {{shareCanvasWidth}}px; height: {{shareCanvasHeight}}px;"
  ></canvas>
</view>
