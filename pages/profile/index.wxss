.page {
  min-height: 100vh;
  padding: 72rpx 28rpx 160rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at 22% 8%, rgba(255, 233, 92, 0.24), transparent 34%),
    radial-gradient(circle at 86% 18%, rgba(156, 231, 255, 0.18), transparent 36%),
    linear-gradient(180deg, #171717 0%, #090909 100%);
}

.top-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 72rpx;
}

.placeholder {
  width: 108rpx;
}

.title {
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
}

.setting-card {
  margin-top: 30rpx;
  padding: 28rpx 24rpx;
  border-radius: 32rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: rgba(255, 255, 255, 0.12);
  border: 1rpx solid rgba(255, 255, 255, 0.24);
  box-shadow: 0 22rpx 62rpx rgba(0, 0, 0, 0.24);
}

.setting-card + .setting-card {
  margin-top: 22rpx;
}

.privacy-card {
  align-items: center;
}

.feedback-card {
  align-items: center;
}

.setting-copy {
  flex: 1;
  min-width: 0;
  padding-right: 24rpx;
}

.setting-title {
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 800;
}

.setting-desc {
  margin-top: 12rpx;
  color: rgba(255, 255, 255, 0.78);
  font-size: 24rpx;
  line-height: 1.45;
}

.setting-arrow {
  color: rgba(255, 255, 255, 0.82);
  font-size: 48rpx;
  line-height: 1;
  font-weight: 300;
}

.guide-mode-options {
  margin-top: 22rpx;
  padding: 6rpx;
  border-radius: 999rpx;
  display: flex;
  background: rgba(255, 255, 255, 0.16);
  border: 1rpx solid rgba(255, 255, 255, 0.28);
}

.guide-mode-option {
  flex: 1;
  height: 58rpx;
  line-height: 58rpx;
  border-radius: 999rpx;
  color: rgba(255, 255, 255, 0.88);
  font-size: 24rpx;
  font-weight: 700;
  text-align: center;
}

.guide-mode-option.active {
  color: #111111;
  background: #ffe95c;
}

.favorite-section {
  margin-top: 30rpx;
}

.section-head {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  padding: 0 6rpx;
}

.section-title {
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 800;
}

.section-desc {
  margin-top: 10rpx;
  color: rgba(255, 255, 255, 0.74);
  font-size: 23rpx;
}

.empty-state {
  margin-top: 20rpx;
  padding: 34rpx 28rpx;
  border-radius: 30rpx;
  text-align: center;
  background: rgba(255, 255, 255, 0.12);
  border: 1rpx solid rgba(255, 255, 255, 0.24);
}

.empty-title {
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 800;
}

.empty-desc {
  margin-top: 12rpx;
  color: rgba(255, 255, 255, 0.74);
  font-size: 24rpx;
  line-height: 1.45;
}

.favorite-list {
  margin-top: 20rpx;
}

.favorite-card {
  min-height: 188rpx;
  margin-bottom: 20rpx;
  padding: 16rpx;
  border-radius: 30rpx;
  box-sizing: border-box;
  display: flex;
  background: rgba(255, 255, 255, 0.12);
  border: 1rpx solid rgba(255, 255, 255, 0.22);
  box-shadow: 0 18rpx 50rpx rgba(0, 0, 0, 0.24);
  overflow: hidden;
}

.favorite-image-wrap {
  flex: 0 0 148rpx;
  width: 148rpx;
  height: 156rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.12);
  position: relative;
  overflow: hidden;
}

.favorite-image {
  width: 100%;
  height: 100%;
  display: block;
}

.favorite-image-loading,
.favorite-image-error {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 14rpx;
  box-sizing: border-box;
  color: rgba(255, 255, 255, 0.8);
  font-size: 21rpx;
  line-height: 1.3;
  text-align: center;
  background: rgba(0, 0, 0, 0.28);
}

.favorite-image-error {
  color: #ffe95c;
  background: rgba(0, 0, 0, 0.46);
}

.favorite-copy {
  flex: 1;
  min-width: 0;
  padding: 8rpx 0 0 20rpx;
}

.favorite-name {
  color: #ffffff;
  font-size: 28rpx;
  line-height: 1.25;
  font-weight: 800;
}

.favorite-tip {
  margin-top: 10rpx;
  color: rgba(255, 233, 92, 0.94);
  font-size: 23rpx;
  line-height: 1.35;
}

.favorite-actions {
  margin-top: 18rpx;
  display: flex;
  justify-content: flex-end;
  gap: 14rpx;
}

.favorite-action {
  min-width: 88rpx;
  height: 52rpx;
  line-height: 52rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  color: #111111;
  font-size: 22rpx;
  font-weight: 800;
  text-align: center;
  background: #ffe95c;
}

.favorite-action.ghost {
  color: rgba(255, 255, 255, 0.9);
  background: rgba(255, 255, 255, 0.16);
  border: 1rpx solid rgba(255, 255, 255, 0.28);
}

.ad-card {
  margin-top: 24rpx;
  overflow: hidden;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.16);
}

.mock-ad {
  min-height: 132rpx;
  padding: 22rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, rgba(255, 233, 92, 0.18), rgba(156, 231, 255, 0.12));
}

.mock-ad-label {
  flex: 0 0 auto;
  padding: 6rpx 10rpx;
  border-radius: 8rpx;
  color: rgba(255, 255, 255, 0.8);
  font-size: 20rpx;
  background: rgba(0, 0, 0, 0.36);
}

.mock-ad-copy {
  flex: 1;
  min-width: 0;
  margin: 0 18rpx;
}

.mock-ad-title {
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 800;
}

.mock-ad-desc {
  margin-top: 8rpx;
  color: rgba(255, 255, 255, 0.74);
  font-size: 22rpx;
}

.mock-ad-action {
  flex: 0 0 auto;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  color: #111111;
  font-size: 22rpx;
  font-weight: 800;
  background: #ffe95c;
}
