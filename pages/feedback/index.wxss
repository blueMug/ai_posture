.page {
  min-height: 100vh;
  padding: 72rpx 28rpx 120rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at 22% 8%, rgba(255, 233, 92, 0.24), transparent 34%),
    radial-gradient(circle at 86% 18%, rgba(156, 231, 255, 0.18), transparent 36%),
    linear-gradient(180deg, #171717 0%, #090909 100%);
}

.top-bar {
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.back-btn,
.placeholder {
  width: 108rpx;
}

.back-btn {
  color: rgba(255, 255, 255, 0.86);
  font-size: 26rpx;
  font-weight: 700;
}

.title {
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
}

.feedback-card,
.tip-card {
  margin-top: 30rpx;
  padding: 32rpx 28rpx;
  border-radius: 32rpx;
  box-sizing: border-box;
  background: rgba(255, 255, 255, 0.12);
  border: 1rpx solid rgba(255, 255, 255, 0.24);
  box-shadow: 0 22rpx 62rpx rgba(0, 0, 0, 0.24);
}

.feedback-title,
.tip-title {
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 800;
}

.feedback-desc,
.tip-desc {
  margin-top: 14rpx;
  color: rgba(255, 255, 255, 0.76);
  font-size: 25rpx;
  line-height: 1.5;
}

.link-box {
  margin-top: 28rpx;
  padding: 22rpx;
  border-radius: 22rpx;
  color: rgba(255, 255, 255, 0.82);
  font-size: 22rpx;
  line-height: 1.45;
  word-break: break-all;
  background: rgba(0, 0, 0, 0.28);
  border: 1rpx solid rgba(255, 255, 255, 0.16);
}

.copy-btn {
  margin-top: 30rpx;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 999rpx;
  color: #111111;
  font-size: 28rpx;
  font-weight: 800;
  background: #ffe95c;
}

.copy-btn::after {
  border: 0;
}
