<view class="page">
  <view class="top-bar">
    <view class="back-btn" bindtap="backToHome">返回</view>
    <view class="title">姿势详情</view>
    <view class="placeholder"></view>
  </view>

  <view class="content">
    <view class="copy">
      <view class="pose-name">{{pose.name}}</view>
      <view class="pose-tip">{{pose.tip}}</view>
      <view class="pose-desc">{{pose.description}}</view>
    </view>

    <view class="photo-card" style="background: {{pose.gradient}};">
      <view class="photo-glow"></view>
      <image
        class="pose-photo"
        src="{{displayImage}}"
        mode="aspectFit"
        bindtap="openCamera"
        binderror="onImageError"
      ></image>
      <view class="tap-tip">点图拍照</view>
    </view>

    <view wx:if="{{adSlot.visible}}" class="ad-card">
      <view wx:if="{{adSlot.isMock}}" class="mock-ad">
        <view class="mock-ad-label">广告</view>
        <view class="mock-ad-copy">
          <view class="mock-ad-title">{{adSlot.mockTitle}}</view>
          <view class="mock-ad-desc">{{adSlot.mockDesc}}</view>
        </view>
        <view class="mock-ad-action">{{adSlot.mockAction}}</view>
      </view>
      <ad
        wx:else
        unit-id="{{adSlot.unitId}}"
        ad-type="{{adSlot.adType}}"
      ></ad>
    </view>
  </view>

  <view class="bottom-panel safe-area-bottom">
    <button class="share-btn" open-type="share">分享</button>
    <button class="shoot-btn" bindtap="openCamera">拍照</button>
  </view>
</view>
