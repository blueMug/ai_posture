.page {
  min-height: 100vh;
  padding: 88rpx 28rpx 150rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at 22% 8%, rgba(255, 233, 92, 0.18), transparent 34%),
    linear-gradient(180deg, #171717 0%, #090909 100%);
}

.top-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 72rpx;
}

.back-btn,
.placeholder {
  width: 108rpx;
}

.back-btn {
  color: rgba(255, 255, 255, 0.86);
  font-size: 26rpx;
}

.title {
  max-width: 430rpx;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 900;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.pose-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 22rpx;
  margin-top: 28rpx;
}

.pose-card {
  min-width: 0;
}

.pose-preview {
  position: relative;
  height: 380rpx;
  border-radius: 30rpx;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.12);
  border: 1rpx solid rgba(255, 255, 255, 0.18);
}

.pose-image {
  position: absolute;
  left: 16rpx;
  right: 16rpx;
  top: 16rpx;
  bottom: 16rpx;
  width: calc(100% - 32rpx);
  height: calc(100% - 32rpx);
}

.image-error {
  position: absolute;
  left: 16rpx;
  right: 16rpx;
  top: 50%;
  transform: translateY(-50%);
  color: rgba(255, 255, 255, 0.84);
  font-size: 22rpx;
  text-align: center;
}

.pose-name {
  margin-top: 14rpx;
  color: #ffffff;
  font-size: 27rpx;
  font-weight: 900;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.pose-tip {
  margin-top: 8rpx;
  color: rgba(255, 255, 255, 0.68);
  font-size: 22rpx;
  line-height: 1.34;
  display: -webkit-box;
  overflow: hidden;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.empty-state {
  margin-top: 180rpx;
  color: rgba(255, 255, 255, 0.72);
  font-size: 28rpx;
  text-align: center;
}
