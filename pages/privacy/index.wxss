.page {
  min-height: 100vh;
  padding: 72rpx 28rpx 140rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at 22% 8%, rgba(255, 233, 92, 0.24), transparent 34%),
    linear-gradient(180deg, #171717 0%, #090909 100%);
}

.top-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 72rpx;
}

.back-btn,
.placeholder {
  width: 108rpx;
}

.back-btn {
  color: rgba(255, 255, 255, 0.88);
  font-size: 26rpx;
  font-weight: 700;
}

.title {
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 800;
}

.hero-card,
.section {
  margin-top: 28rpx;
  padding: 28rpx 24rpx;
  border-radius: 32rpx;
  box-sizing: border-box;
  background: rgba(255, 255, 255, 0.12);
  border: 1rpx solid rgba(255, 255, 255, 0.24);
  box-shadow: 0 22rpx 62rpx rgba(0, 0, 0, 0.24);
}

.hero-title,
.section-title {
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 900;
}

.hero-desc,
.privacy-item {
  margin-top: 16rpx;
  color: rgba(255, 255, 255, 0.78);
  font-size: 25rpx;
  line-height: 1.55;
}

.privacy-item {
  padding-left: 20rpx;
  border-left: 4rpx solid #ffe95c;
}
