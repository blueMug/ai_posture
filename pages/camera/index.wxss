.page {
  width: 100vw;
  height: 100vh;
  overflow: hidden;
  background: #000000;
}

.camera {
  width: 100vw;
  height: calc(100vh - 306rpx);
}

.camera {
  display: block;
}

.top-bar {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  z-index: 10;
  height: 160rpx;
  padding: 72rpx 32rpx 0;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(180deg, rgba(0, 0, 0, 0.45), rgba(0, 0, 0, 0));
}

.title {
  font-size: 34rpx;
  font-weight: 600;
  color: #ffffff;
}

.pose-stage {
  position: absolute;
  left: 7vw;
  right: 7vw;
  top: 13vh;
  bottom: 4vh;
  z-index: 5;
}

.pose-name {
  position: absolute;
  left: 50%;
  top: 0;
  transform: translateX(-50%);
  padding: 12rpx 28rpx;
  border-radius: 999rpx;
  color: rgba(255, 255, 255, 0.92);
  font-size: 26rpx;
  font-weight: 600;
  background: rgba(0, 0, 0, 0.24);
  border: 1rpx solid rgba(255, 255, 255, 0.24);
}

.pose-guide-image {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
}

.pose-guide-main {
  z-index: 2;
}

.pose-guide-boost {
  z-index: 1;
  opacity: 0.78;
}

.outline-guide-image {
  opacity: 1;
}

.photo-guide-image {
  opacity: 0.42;
}

.pose-guide-box {
  position: absolute;
  left: 0;
  top: 8%;
  z-index: 6;
  width: 100%;
  height: 88%;
}

.guide-error-tip {
  position: absolute;
  left: 50%;
  top: 50%;
  z-index: 8;
  transform: translate(-50%, -50%);
  padding: 14rpx 24rpx;
  border-radius: 999rpx;
  color: rgba(255, 255, 255, 0.92);
  font-size: 24rpx;
  background: rgba(0, 0, 0, 0.48);
  border: 1rpx solid rgba(255, 255, 255, 0.24);
}

.bottom-panel {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 20;
  min-height: 306rpx;
  padding: 28rpx 28rpx 44rpx;
  box-sizing: border-box;
  background:
    linear-gradient(0deg, rgba(0, 0, 0, 0.94), rgba(0, 0, 0, 0.82)),
    #000000;
}

.shoot-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.guide-toggle-btn,
.select-pose-btn {
  width: 84rpx;
  height: 84rpx;
}

.guide-toggle-btn {
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  background: rgba(0, 0, 0, 0.38);
  border: 1rpx solid rgba(255, 255, 255, 0.36);
}

.guide-toggle-btn.active {
  background: rgba(255, 233, 92, 0.18);
  border-color: rgba(255, 233, 92, 0.82);
}

.guide-toggle-btn.muted {
  opacity: 0.72;
}

.model-toggle-btn {
  position: relative;
  width: 92rpx;
  height: 92rpx;
  background: rgba(255, 255, 255, 0.08);
  border-width: 3rpx;
  box-shadow: 0 10rpx 28rpx rgba(0, 0, 0, 0.26);
}

.model-toggle-image {
  width: 100%;
  height: 100%;
  display: block;
}

.model-toggle-mask {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 34rpx;
  line-height: 34rpx;
  color: rgba(255, 255, 255, 0.94);
  font-size: 18rpx;
  text-align: center;
  background: rgba(0, 0, 0, 0.58);
}

.select-pose-btn {
  width: 108rpx;
  height: 68rpx;
  line-height: 68rpx;
  border-radius: 999rpx;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 700;
  text-align: center;
  background: rgba(0, 0, 0, 0.38);
  border: 1rpx solid rgba(255, 255, 255, 0.36);
}

.eye-icon {
  position: relative;
  width: 44rpx;
  height: 28rpx;
  border: 4rpx solid #ffffff;
  border-radius: 50%;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
}

.eye-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #ffffff;
}

.eye-slash {
  position: absolute;
  left: 18rpx;
  top: -10rpx;
  width: 5rpx;
  height: 48rpx;
  border-radius: 999rpx;
  background: #ffffff;
  transform: rotate(45deg);
}

.shutter-group {
  display: flex;
  align-items: center;
}

.switch-icon-btn {
  width: 72rpx;
  height: 72rpx;
  line-height: 72rpx;
  margin-left: 22rpx;
  border-radius: 999rpx;
  color: #ffffff;
  font-size: 40rpx;
  text-align: center;
  background: rgba(0, 0, 0, 0.38);
  border: 1rpx solid rgba(255, 255, 255, 0.36);
}

.camera-zoom-row {
  width: 590rpx;
  height: 72rpx;
  margin: 22rpx auto 0;
  padding: 0 20rpx;
  border-radius: 36rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: rgba(0, 0, 0, 0.34);
  border: 1rpx solid rgba(255, 255, 255, 0.28);
}

.zoom-slider {
  flex: 1;
  margin: 0 10rpx;
}

.zoom-label {
  width: 64rpx;
  color: rgba(255, 255, 255, 0.88);
  font-size: 22rpx;
  font-weight: 700;
  text-align: center;
}

.shutter {
  width: 132rpx;
  height: 132rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.28);
  display: flex;
  align-items: center;
  justify-content: center;
}

.shutter-inner {
  width: 104rpx;
  height: 104rpx;
  border-radius: 999rpx;
  background: #ffffff;
}
