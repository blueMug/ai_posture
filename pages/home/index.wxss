.page {
  min-height: 100vh;
  padding: 104rpx 28rpx 160rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at 22% 8%, rgba(255, 233, 92, 0.24), transparent 34%),
    radial-gradient(circle at 86% 18%, rgba(156, 231, 255, 0.18), transparent 36%),
    linear-gradient(180deg, #171717 0%, #090909 100%);
}

.brand-copy {
  margin-bottom: 24rpx;
  padding: 0 6rpx;
}

.brand-name {
  color: #ffffff;
  font-size: 44rpx;
  font-weight: 900;
  letter-spacing: 1rpx;
}

.brand-tagline {
  margin-top: 10rpx;
  color: rgba(255, 233, 92, 0.94);
  font-size: 26rpx;
  font-weight: 700;
}

.search-card {
  height: 88rpx;
  padding: 0 24rpx;
  border-radius: 28rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.16);
  border: 1rpx solid rgba(255, 255, 255, 0.3);
}

.search-icon {
  margin-right: 14rpx;
  color: rgba(255, 255, 255, 0.86);
  font-size: 34rpx;
}

.search-input {
  flex: 1;
  min-width: 0;
  height: 88rpx;
  color: #ffffff;
  font-size: 26rpx;
}

.search-placeholder {
  color: rgba(255, 255, 255, 0.72);
}

.search-clear {
  flex: 0 0 auto;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  color: #111111;
  font-size: 22rpx;
  font-weight: 700;
  background: #ffe95c;
}

.empty-state {
  margin-top: 32rpx;
  padding: 34rpx 28rpx;
  border-radius: 30rpx;
  text-align: center;
  background: rgba(255, 255, 255, 0.12);
  border: 1rpx solid rgba(255, 255, 255, 0.24);
}

.empty-title {
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
}

.empty-desc {
  margin-top: 12rpx;
  color: rgba(255, 255, 255, 0.76);
  font-size: 24rpx;
}

.daily-section,
.topic-section,
.more-head {
  margin-top: 32rpx;
}

.more-head {
  padding: 0 6rpx;
}

.more-kicker {
  display: inline-flex;
  align-items: center;
  height: 38rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  color: #111111;
  font-size: 22rpx;
  font-weight: 900;
  background: rgba(255, 233, 92, 0.92);
}

.more-desc {
  margin-top: 12rpx;
  color: rgba(255, 255, 255, 0.58);
  font-size: 22rpx;
  line-height: 1.4;
}

.type-entry-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
  margin-top: 20rpx;
}

.type-entry-card {
  position: relative;
  display: flex;
  align-items: center;
  min-height: 150rpx;
  padding: 20rpx 18rpx 20rpx 22rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.18);
  border-radius: 28rpx;
  box-sizing: border-box;
  background: rgba(255, 255, 255, 0.10);
  overflow: hidden;
}

.type-entry-copy {
  flex: 1;
  min-width: 0;
  padding-right: 14rpx;
}

.type-entry-name {
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 800;
}

.type-entry-desc {
  margin-top: 10rpx;
  color: rgba(255, 255, 255, 0.62);
  font-size: 22rpx;
  line-height: 1.35;
  display: -webkit-box;
  overflow: hidden;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.type-entry-image-wrap {
  position: relative;
  flex: 0 0 84rpx;
  width: 84rpx;
  height: 104rpx;
  border-radius: 22rpx;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.12);
}

.type-entry-image {
  width: 100%;
  height: 100%;
}

.type-entry-image-error {
  left: 8rpx;
  right: 8rpx;
  font-size: 18rpx;
}

.topic-section-head {
  padding: 0 6rpx;
}

.topic-kicker {
  display: inline-flex;
  align-items: center;
  height: 40rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  color: #111111;
  font-size: 22rpx;
  font-weight: 900;
  background: #ffe95c;
}

.topic-title {
  margin-top: 18rpx;
  color: #ffffff;
  font-size: 38rpx;
  line-height: 1.22;
  font-weight: 900;
}

.topic-subtitle {
  margin-top: 12rpx;
  color: rgba(255, 255, 255, 0.78);
  font-size: 25rpx;
  line-height: 1.45;
}

.topic-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 18rpx;
  margin-top: 22rpx;
}

.topic-card {
  position: relative;
  min-height: 220rpx;
  padding: 24rpx 116rpx 24rpx 22rpx;
  border-radius: 30rpx;
  box-sizing: border-box;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.12);
  border: 1rpx solid rgba(255, 255, 255, 0.2);
}

.topic-image {
  position: absolute;
  right: -8rpx;
  bottom: -22rpx;
  width: 134rpx;
  height: 166rpx;
  opacity: 0.82;
  pointer-events: none;
}

.topic-mask {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  pointer-events: none;
  background:
    radial-gradient(circle at 90% 92%, rgba(255, 233, 92, 0.22), transparent 42%),
    linear-gradient(135deg, rgba(255, 255, 255, 0.12), rgba(255, 255, 255, 0.04));
}

.home-image-loading {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 3;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.22);
  pointer-events: none;
}

.home-image-loading.compact {
  background: rgba(0, 0, 0, 0.12);
}

.topic-loading {
  left: auto;
  right: 8rpx;
  top: 18rpx;
  bottom: 18rpx;
  width: 126rpx;
  z-index: 1;
  background: transparent;
}

.home-loading-spinner {
  width: 44rpx;
  height: 44rpx;
  border-radius: 999rpx;
  border: 5rpx solid rgba(255, 255, 255, 0.2);
  border-top-color: #ffe95c;
  animation: home-image-loading-spin 0.8s linear infinite;
}

.home-image-loading.compact .home-loading-spinner {
  width: 30rpx;
  height: 30rpx;
  border-width: 4rpx;
}

.home-loading-text {
  margin-top: 12rpx;
  color: rgba(255, 255, 255, 0.9);
  font-size: 21rpx;
  font-weight: 800;
}

@keyframes home-image-loading-spin {
  from {
    transform: rotate(0deg);
  }

  to {
    transform: rotate(360deg);
  }
}

.topic-copy {
  position: relative;
  z-index: 2;
  pointer-events: none;
}

.topic-card-title {
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 900;
}

.topic-card-desc {
  margin-top: 10rpx;
  color: rgba(255, 255, 255, 0.72);
  font-size: 21rpx;
  line-height: 1.4;
  word-break: break-all;
}

.topic-update-tip {
  margin-top: 18rpx;
  color: rgba(255, 255, 255, 0.56);
  font-size: 23rpx;
  text-align: center;
}

.section-head {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  margin-bottom: 20rpx;
  padding: 0 6rpx;
}

.section-head.compact {
  margin-bottom: 18rpx;
}

.section-kicker {
  display: inline-flex;
  align-items: center;
  height: 38rpx;
  padding: 0 16rpx;
  margin-bottom: 12rpx;
  border-radius: 999rpx;
  color: #111111;
  font-size: 22rpx;
  font-weight: 800;
  background: #ffe95c;
}

.section-title {
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 800;
}

.section-subtitle {
  margin-top: 8rpx;
  color: rgba(255, 255, 255, 0.72);
  font-size: 23rpx;
  line-height: 1.42;
}

.section-link {
  flex: 0 0 auto;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  color: #111111;
  font-size: 22rpx;
  font-weight: 800;
  background: #ffe95c;
}

.daily-scroll {
  width: 100%;
}

.daily-list {
  display: flex;
  padding-right: 6rpx;
}

.daily-card {
  flex: 0 0 246rpx;
  margin-right: 20rpx;
  padding: 16rpx;
  border-radius: 34rpx;
  box-sizing: border-box;
  background: rgba(255, 255, 255, 0.14);
  border: 1rpx solid rgba(255, 255, 255, 0.22);
  box-shadow: 0 24rpx 64rpx rgba(0, 0, 0, 0.24);
}

.daily-image-wrap {
  position: relative;
  height: 238rpx;
  border-radius: 26rpx;
  overflow: hidden;
}

.daily-image {
  position: absolute;
  left: 14rpx;
  right: 14rpx;
  top: 14rpx;
  bottom: 14rpx;
  width: calc(100% - 28rpx);
  height: calc(100% - 28rpx);
}

.daily-name {
  margin-top: 16rpx;
  color: #ffffff;
  font-size: 27rpx;
  font-weight: 700;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.daily-action {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 48rpx;
  margin-top: 14rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  color: #111111;
  font-size: 22rpx;
  font-weight: 800;
  background: #ffe95c;
}

.category {
  margin-top: 36rpx;
}

.category-head {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  margin-bottom: 20rpx;
  padding: 0 6rpx;
}

.category-title {
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 700;
}

.category-subtitle {
  margin-top: 8rpx;
  color: rgba(255, 255, 255, 0.74);
  font-size: 23rpx;
}

.category-count {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  color: #111111;
  font-size: 22rpx;
  font-weight: 700;
  background: #ffe95c;
}

.pose-list {
  display: flex;
  flex-direction: column;
}

.pose-card {
  display: flex;
  min-height: 248rpx;
  margin-bottom: 24rpx;
  padding: 18rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.22);
  border-radius: 36rpx;
  box-sizing: border-box;
  background: rgba(255, 255, 255, 0.12);
  box-shadow: 0 24rpx 70rpx rgba(0, 0, 0, 0.28);
  overflow: hidden;
}

.preview {
  position: relative;
  flex: 0 0 210rpx;
  height: 212rpx;
  border-radius: 28rpx;
  overflow: hidden;
}

.preview-shine {
  position: absolute;
  left: -40rpx;
  top: -70rpx;
  width: 190rpx;
  height: 190rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.34);
}

.mini-stage {
  position: absolute;
  left: 16rpx;
  right: 16rpx;
  top: 18rpx;
  bottom: 16rpx;
}

.mini-guide-image {
  position: absolute;
  left: 0;
  top: 0;
  z-index: 2;
  width: 100%;
  height: 100%;
  opacity: 0.96;
}

.mini-image-error {
  position: absolute;
  left: 16rpx;
  right: 16rpx;
  top: 50%;
  z-index: 4;
  transform: translateY(-50%);
  padding: 10rpx 8rpx;
  border-radius: 16rpx;
  color: rgba(255, 255, 255, 0.88);
  font-size: 22rpx;
  text-align: center;
  background: rgba(0, 0, 0, 0.38);
}

.pose-info {
  flex: 1;
  min-width: 0;
  padding: 8rpx 4rpx 4rpx 24rpx;
  box-sizing: border-box;
}

.pose-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.pose-name {
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 700;
}

.pose-action {
  flex: 0 0 auto;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  color: #111111;
  font-size: 22rpx;
  font-weight: 700;
  background: #ffe95c;
}

.pose-tip {
  margin-top: 16rpx;
  color: rgba(255, 233, 92, 0.94);
  font-size: 24rpx;
  line-height: 1.42;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.ad-card {
  margin-top: 18rpx;
  overflow: hidden;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.16);
}

.mock-ad {
  min-height: 132rpx;
  padding: 22rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, rgba(255, 233, 92, 0.18), rgba(156, 231, 255, 0.12));
}

.mock-ad-label {
  flex: 0 0 auto;
  padding: 6rpx 10rpx;
  border-radius: 8rpx;
  color: rgba(255, 255, 255, 0.8);
  font-size: 20rpx;
  background: rgba(0, 0, 0, 0.36);
}

.mock-ad-copy {
  flex: 1;
  min-width: 0;
  margin: 0 18rpx;
}

.mock-ad-title {
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 800;
}

.mock-ad-desc {
  margin-top: 8rpx;
  color: rgba(255, 255, 255, 0.74);
  font-size: 22rpx;
}

.mock-ad-action {
  flex: 0 0 auto;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  color: #111111;
  font-size: 22rpx;
  font-weight: 800;
  background: #ffe95c;
}
