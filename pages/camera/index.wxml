<view class="page">
  <camera
    class="camera"
    device-position="{{devicePosition}}"
    flash="off"
    resolution="high"
    binderror="onCameraError"
  >
    <cover-view class="top-bar">
      <cover-view class="ghost-btn" bindtap="backToHome">选姿势</cover-view>
      <cover-view class="title">姿势引导相机</cover-view>
      <cover-view class="top-placeholder"></cover-view>
    </cover-view>

    <cover-view class="pose-stage">
      <cover-view class="pose-name">{{currentTemplate.name}}</cover-view>
      <cover-view
        wx:if="{{currentTemplate.guideImage}}"
        class="pose-guide-box"
        style="{{guideBoxStyle}}"
        catchtouchstart="onGuideTouchStart"
        catchtouchmove="onGuideTouchMove"
        catchtouchend="onGuideTouchEnd"
        catchtouchcancel="onGuideTouchEnd"
      >
        <cover-image
          class="pose-guide-image"
          src="{{currentTemplate.guideImage}}"
        ></cover-image>
        <cover-view
          class="resize-handle"
          catchtouchstart="onResizeTouchStart"
          catchtouchmove="onResizeTouchMove"
          catchtouchend="onGuideTouchEnd"
          catchtouchcancel="onGuideTouchEnd"
        >
          <cover-view class="resize-handle-dot"></cover-view>
        </cover-view>
      </cover-view>
      <cover-view wx:if="{{currentTemplate.guideImage}}" class="guide-help">拖动图片移动，拖右下角缩放 {{guideScaleText}}</cover-view>
      <cover-view wx:if="{{currentTemplate.guideImage}}" class="guide-presets">
        <cover-view
          wx:for="{{guideScalePresets}}"
          wx:key="label"
          class="guide-preset-btn"
          data-scale="{{item.scale}}"
          bindtap="setGuideScalePreset"
        >{{item.label}}</cover-view>
      </cover-view>
      <cover-view wx:if="{{currentTemplate.guideImage}}" class="guide-tools">
        <cover-view class="guide-tool-btn" bindtap="zoomGuideOut">-</cover-view>
        <cover-view class="guide-tool-btn reset" bindtap="resetGuidePlacement">重置</cover-view>
        <cover-view class="guide-tool-btn" bindtap="zoomGuideIn">+</cover-view>
      </cover-view>
      <cover-view wx:if="{{currentTemplate.guideImage}}" class="guide-move-tools">
        <cover-view class="guide-move-row">
          <cover-view class="guide-move-btn placeholder"></cover-view>
          <cover-view class="guide-move-btn" bindtap="moveGuideUp">上</cover-view>
          <cover-view class="guide-move-btn placeholder"></cover-view>
        </cover-view>
        <cover-view class="guide-move-row">
          <cover-view class="guide-move-btn" bindtap="moveGuideLeft">左</cover-view>
          <cover-view class="guide-move-btn" bindtap="moveGuideDown">下</cover-view>
          <cover-view class="guide-move-btn" bindtap="moveGuideRight">右</cover-view>
        </cover-view>
      </cover-view>
    </cover-view>

    <cover-view class="camera-switch-float" bindtap="switchCamera">切换镜头</cover-view>

    <cover-view class="bottom-panel safe-area-bottom">
      <cover-view class="template-switch">
        <cover-view class="round-btn" bindtap="prevTemplate">上一个</cover-view>
        <cover-view class="template-text">{{currentTemplate.tip}}</cover-view>
        <cover-view class="round-btn" bindtap="nextTemplate">下一个</cover-view>
      </cover-view>

      <cover-view class="shoot-row">
        <cover-view class="small-btn" bindtap="clearGuide">隐藏线条</cover-view>
        <cover-view class="shutter" bindtap="takePhoto">
          <cover-view class="shutter-inner"></cover-view>
        </cover-view>
        <cover-view class="small-btn" bindtap="showGuide">显示线条</cover-view>
      </cover-view>
      <cover-view
        class="confirm-toggle {{keepGuideForConfirm ? 'active' : ''}}"
        bindtap="toggleKeepGuideForConfirm"
      >
        <cover-view class="toggle-dot"></cover-view>
        <cover-view class="toggle-text">拍后轮廓确认</cover-view>
      </cover-view>
    </cover-view>
  </camera>
</view>
