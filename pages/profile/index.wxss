.page {
  min-height: 100vh;
  padding: 72rpx 28rpx 160rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at 18% 8%, rgba(255, 233, 92, 0.24), transparent 34%),
    radial-gradient(circle at 86% 18%, rgba(156, 231, 255, 0.18), transparent 36%),
    linear-gradient(180deg, #171717 0%, #090909 100%);
}

.top-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 72rpx;
}

.placeholder {
  width: 108rpx;
}

.title {
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
}

.setting-card {
  margin-top: 30rpx;
  padding: 28rpx 24rpx;
  border-radius: 32rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: rgba(255, 255, 255, 0.12);
  border: 1rpx solid rgba(255, 255, 255, 0.24);
  box-shadow: 0 22rpx 62rpx rgba(0, 0, 0, 0.24);
}

.setting-card + .setting-card {
  margin-top: 22rpx;
}

.setting-copy {
  flex: 1;
  min-width: 0;
  padding-right: 24rpx;
}

.setting-title {
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 800;
}

.setting-desc {
  margin-top: 12rpx;
  color: rgba(255, 255, 255, 0.78);
  font-size: 24rpx;
  line-height: 1.45;
}

.guide-mode-options {
  margin-top: 22rpx;
  padding: 6rpx;
  border-radius: 999rpx;
  display: flex;
  background: rgba(255, 255, 255, 0.16);
  border: 1rpx solid rgba(255, 255, 255, 0.28);
}

.guide-mode-option {
  flex: 1;
  height: 58rpx;
  line-height: 58rpx;
  border-radius: 999rpx;
  color: rgba(255, 255, 255, 0.88);
  font-size: 24rpx;
  font-weight: 700;
  text-align: center;
}

.guide-mode-option.active {
  color: #111111;
  background: #ffe95c;
}

.ad-card {
  margin-top: 24rpx;
  overflow: hidden;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.16);
}
