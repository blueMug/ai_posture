.page {
  position: relative;
  width: 100vw;
  height: 100vh;
  overflow: hidden;
  background: #0d0d0d;
}

.photo {
  width: 100vw;
  height: 100vh;
}

.guide-preview {
  position: absolute;
  z-index: 1;
  opacity: 0.92;
}

.top-bar {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  z-index: 2;
  height: 160rpx;
  padding: 72rpx 32rpx 0;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: linear-gradient(180deg, rgba(0, 0, 0, 0.68), rgba(0, 0, 0, 0));
}

.title {
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 600;
}

.back-btn,
.placeholder {
  width: 112rpx;
}

.back-btn {
  height: 60rpx;
  line-height: 60rpx;
  border-radius: 30rpx;
  color: #ffffff;
  font-size: 26rpx;
  text-align: center;
  background: rgba(0, 0, 0, 0.62);
  border: 2rpx solid rgba(255, 255, 255, 0.62);
}

.bottom-panel {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 2;
  padding: 36rpx 32rpx 56rpx;
  box-sizing: border-box;
  background: linear-gradient(0deg, rgba(0, 0, 0, 0.68), rgba(0, 0, 0, 0));
}

.hint {
  margin-bottom: 24rpx;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 700;
  text-align: center;
}

.save-btn,
.share-guide-btn {
  height: 92rpx;
  line-height: 92rpx;
  border-radius: 46rpx;
  color: #111111;
  font-size: 30rpx;
  font-weight: 600;
  background: #ffe95c;
}

.share-guide-btn {
  margin-bottom: 20rpx;
}

.confirm-actions {
  display: flex;
  align-items: center;
}

.discard-btn,
.accept-btn {
  flex: 1;
  height: 92rpx;
  line-height: 92rpx;
  margin: 0;
  border-radius: 46rpx;
  font-size: 30rpx;
  font-weight: 600;
}

.discard-btn {
  margin-right: 20rpx;
  color: #ffffff;
  background: rgba(255, 255, 255, 0.28);
}

.accept-btn {
  color: #111111;
  background: #ffe95c;
}

.save-btn::after,
.share-guide-btn::after,
.discard-btn::after,
.accept-btn::after {
  border: 0;
}

.share-canvas {
  position: absolute;
  left: -9999px;
  top: -9999px;
  z-index: -1;
}
